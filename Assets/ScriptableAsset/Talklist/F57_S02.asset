  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3060\u304B\u3089\u3053\u306E\u8FBA\u306B\u843D\u3061\u3066\u308B\u885D\u6483\u306B\u5F31\u3044\u93A7\u306F\u3001\n\u3076\u3063\u3061\u3083\u3051\u7F60\u30A2\u30A4\u30C6\u30E0\u3060\u305C\uFF01"
