  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u65AC\u3068\u304B\u7A81\u3068\u304B\u306F\u3001\u4EBA\u9593\u306E\u6B66\u5668\u3092\u524D\u63D0\u306B\u3057\u305F\u5C5E\u6027\u3060\u304B\u3089\u306A\u2026\u2026\n\u722A\u3068\u304B\u6301\u3063\u3066\u305D\u3046\u306A\u6575\u306F\u65AC\u5C5E\u6027\u3060\u304C\u3001\u5927\u534A\u306F\u6BB4\u5C5E\u6027\u3060\u3002"
