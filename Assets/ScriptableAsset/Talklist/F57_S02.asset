    text: "\u6BB4\u3001\u65AC\u3001\u7A81\u3001\u3053\u306E3\u3064\u306E\u3046\u3061\u3069\u308C\u3092\u91CD\u8996\u3059\u3079\u304D\u304B\uFF1F\n\u6B63\u76F4\u306B\u8A00\u3063\u3066\u6BB4\u3060\u3068\u601D\u3046\u305C\u3002"
