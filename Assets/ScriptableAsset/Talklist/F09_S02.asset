  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30B9\u30C6\u632F\u308A\u306F\u3061\u3083\u3093\u3068\u3057\u3066\u308B\u304B\uFF1F\n\u307E\u3041\u3001\u3057\u3066\u306A\u304B\u3063\u305F\u30899\u968E\u306B\u6765\u308B\u306E\u306F\u96E3\u3057\u3044\u3060\u308D\u3046\u3051\u3069\u306A\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u5927\u62B5\u306E\u4EBA\u306F\u76F4\u611F\u7684\u306BSTR\u3068\u304BVIT\u3068\u304B\u306B\u632F\u308B\u3068\u601D\u3046\u3093\u3060\u3088\u306A\u3002\n\u5E8F\u76E4\u3060\u3057\u305D\u308C\u3067\u554F\u984C\u7121\u3044\u305C\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "STR\u306F\u7269\u7406\u653B\u6483\u529B\u306B\u76F4\u7D50\u3059\u308B\u305C\uFF01\nSTR\u304C\u9AD8\u3051\u308C\u3070\u653B\u6483\u529B\u304C\u4F4E\u3044\u3051\u3069\u30B9\u30AD\u30EB\u3068\u304B\u304C\u512A\u79C0\u306A\u6B66\u5668\u304C\u4F7F\u3048\u3066\u3001\nSTR\u304C\u4F4E\u304F\u3066\u3082\u6B66\u5668\u304C\u5F37\u3051\u308C\u3070\u3042\u308B\u7A0B\u5EA6\u30AB\u30D0\u30FC\u3067\u304D\u308B\u305C\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "VIT\u306F\u7269\u7406\u9632\u5FA1\u3068HP\u306B\u5F71\u97FF\u3059\u308B\u305C\uFF01\n\u9632\u5FA12\u3067\u5927\u4F531\u30C0\u30E1\u30FC\u30B8\u8EFD\u6E1B\u3067\u304D\u308B\u305C\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u308C\u3092\u3084\u308B\u304B\u3089\u3001\u5B9F\u969B\u306B\u632F\u3063\u3066\n\u8A73\u7D30\u306E\u30B9\u30C6\u30FC\u30BF\u30B9\u3068\u304B\u3092\u78BA\u8A8D\u3057\u3066\u304F\u308C\u3088\u306A\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
