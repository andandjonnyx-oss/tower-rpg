  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u554F\u984C\uFF01\u3000\u305F\u304B\u3057\u541B\u306F\u3001HP\u309220\u5897\u3084\u3059\u9769\u306E\u93A7\u30923\u3064\u6301\u3063\u3066\u3044\u307E\u3059\u3002\n\u305F\u304B\u3057\u541B\u306EHP\u306F\u3044\u304F\u3064\u5897\u3048\u305F\u3067\u3057\u3087\u3046\u304B\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u99AC\u9E7F\u306B\u3059\u308B\u306A\u3088\u300160\u3060\u308D\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3076\u3076\u30FC\u3063\uFF01\u3000\u6B63\u89E3\u306F24\uFF01\n\u6240\u6301\u3067\u80FD\u529B\u304C\u4E0A\u304C\u308B\u7CFB\u306E\u30A2\u30A4\u30C6\u30E0\u306F\u3001\n\u4E00\u756A\u5927\u304D\u3044\u6570\u5024\u4EE5\u5916\u306F0.1\u500D\u306B\u306A\u308A\u307E\u30FC\u3059\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u304A\u304B\u3057\u3044\u3060\u308D\u305D\u308C\u306F\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305D\u3093\u306A\u4E8B\u3092\u8A00\u3063\u305F\u3089\u93A7\u3092\u7740\u306A\u304F\u3066\u3082\u6301\u3063\u3066\u308B\u3060\u3051\u3067HP\u304C\u4E0A\u304C\u3063\u305F\u308A\u3001\n\u93A7\u3060\u308D\u3046\u3068\u85AC\u8349\u3060\u308D\u3046\u3068\u5927\u304D\u3055\u304C\u540C\u3058\u306720\u500B\u307E\u3067\u6301\u3066\u308B\u65B9\u304C\n\u304A\u304B\u3057\u3044\u3060\u308D\u3046\u304C\uFF01\uFF01\uFF01\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
