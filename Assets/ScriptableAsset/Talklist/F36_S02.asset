  id: F36_S02
  zukanTitle: "\u305D\u3093\u306A\u306B\u5F37\u6575\u3058\u3083\u306A\u3044\u30BE\u30FC\u30F3"
  floor: 36
  step: 2
  backgroundImage: {fileID: 0}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6BCE\u5EA6\u304A\u306A\u3058\u307F\u5F37\u6575\u30BE\u30FC\u30F3\uFF01\n\u3068\u8A00\u3063\u3066\u3082\u3001\u3053\u306E\u30D5\u30ED\u30A2\u306B\u95A2\u3057\u3066\u306F\u3001\n\u524D\u534A\u306B\u51FA\u3066\u6765\u305F\u30D6\u30C4\u30EA\u30CB\u30C4\u30E8\u30A4\u30E4\u30C4\u3068\u304B\u3001\n\u30A2\u30A4\u30C6\u30E0\u3092\u98DF\u3046\u306F\u3089\u307A\u3053\u30A2\u30AA\u30B1\u30E0\u30B7\u306E\u65B9\u304C\u5384\u4ECB\u304B\u3082\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u305A\u306F\u708E\u306E\u5316\u8EAB\u3002\n\u307E\u3041\u3001\u540D\u524D\u304C\u5168\u3066\u3060\u3057\u3001\u8A00\u3046\u4E8B\u306F\u7121\u3044\u3088\u306A\u3002\n\u8B77\u7B26\uFF11\u3064\u6301\u3063\u3066\u308B\u3060\u3051\u3067\u304B\u306A\u308A\u697D\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B21\u306B\u5927\u8759\u8760\u3002\n\u8759\u8760\u3068\u9055\u3063\u3066\u3001\u6BD2\u3082\u9EBB\u75FA\u3082\u4F7F\u3063\u3066\u304F\u308B\u305E\u3002\n\u56DE\u907F\u3082\u307E\u3041\u307E\u3041\u9AD8\u3044\u304B\u3089\u72B6\u614B\u7570\u5E38\u307E\u307F\u308C\u306B\u3055\u305B\u3089\u308C\u304C\u3061\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6700\u5F8C\u306B\u30ED\u30B0\u57CB\u3081\u5C3D\u304F\u3059\u304F\u3093\u3002\n\u3053\u3063\u3061\u306E\u9632\u5FA1\u304C\u6975\u7AEF\u306B\u4F4E\u304F\u306A\u304D\u3083\u96D1\u9B5A\u3082\u3044\u3044\u3068\u3053\u3060\u305C\u3002\n\u6226\u95D8\u306E\u30C6\u30F3\u30DD\u304C\u60AA\u304F\u306A\u308B\u3063\u3066\u554F\u984C\u70B9\u306F\u3042\u308B\u304C\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
  rewardItem: {fileID: 0}
