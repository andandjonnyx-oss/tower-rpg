  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B63\u89E3\u2026\u2026\u546A\u3044\u306E\u30A2\u30A4\u30C6\u30E0\u6CA2\u5C71\u6301\u3063\u305F\u3089\u52B9\u679C\u304C\u8584\u308C\u308B\u306A\u3093\u3066\u3001\n\u90FD\u5408\u306E\u826F\u3059\u304E\u308B\u8A71\u3060\u304B\u3089\u306A\u3002\u305D\u3053\u306F\u5168\u90E8\u53CD\u6620\u3060\u3002\n\u307E\u3041\u305D\u3093\u306A\u8A33\u3067\u30C7\u30E1\u30EA\u30C3\u30C8\u30A2\u30A4\u30C6\u30E0\u306E\u6301\u3061\u3059\u304E\u306B\u306F\u6CE8\u610F\u3060\u3002"
