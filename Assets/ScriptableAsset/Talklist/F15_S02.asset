    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u8CA0\u306E\u5024\u306F\u8907\u6570\u6301\u3068\u3046\u304C100%\u53CD\u6620\u3067\u3001\n50+5\xD72-30\xD73=-30\u3060\u308D\uFF1F"
