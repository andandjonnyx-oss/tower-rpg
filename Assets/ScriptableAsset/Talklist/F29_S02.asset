  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u81EA\u7206\u3057\u3066\u308B\u304B\uFF1F\n\u307E\u3060\u3057\u3066\u306A\u3044\u306A\u3089\u5263\u3092\u3084\u308B\u3088\u3002\n\u81EA\u7206\u306F\u7537\u306E\u30ED\u30DE\u30F3\u3060\u3082\u3093\u306A\uFF01"
