    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3061\u306A\u307F\u306B\u3053\u3063\u3061\u306E\u53CD\u52D5\u3084\u81EA\u7206\u3067\u76F8\u6253\u3061\u306B\u306A\u3063\u305F\u5834\u5408\u3001\n\u52DD\u5229\u6271\u3044\u3068\u306A\u3063\u3066HP\u30821\u6B8B\u3063\u3066\u5FA9\u5E30\u3059\u308B\u3093\u3060\u304C\u3001"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u9006\u306B\u5411\u3053\u3046\u306E\u81EA\u7206\u3067\u76F8\u6253\u3061\u306B\u306A\u3063\u305F\u5834\u5408\u306F\u3001\n\u3053\u3063\u3061\u306E\u8CA0\u3051\u6271\u3044\u3060\u304B\u3089\u6CE8\u610F\u3057\u308D\u3088\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u306F\uFF1F\u3000\u5927\u4EBA\u6C17\u30B7\u30EA\u30FC\u30BA\u3067\u306F\u81EA\u7206\u3057\u305F\u65B9\u304C\u8CA0\u3051\uFF1F\n\u305D\u3082\u305D\u3082\u5BFE\u6226\u3058\u3083\u7121\u304F\u3066\u96D1\u9B5A\u6226\u3060\u308D\u3046\u304C\u2026\u2026"
