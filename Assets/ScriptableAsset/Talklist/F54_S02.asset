  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u546A\u3044\u306F\u706B\u3068\u304B\u6C37\u3068\u304B\u9B54\u6CD5\u5C5E\u6027\u306E\u8010\u6027\u304C-100\u3001\n\u30AC\u30E9\u30B9\u306F\u6BB4\u3068\u304B\u7A81\u3068\u304B\u7269\u7406\u5C5E\u6027\u306E\u8010\u6027\u304C-100\u3055\u308C\u308B\u3002\n\u7D20\u306E\u72B6\u614B\u3067\u53D7\u3051\u308B\u3068\u30C0\u30E1\u30FC\u30B8\u500D\u3060\u306A\u3002"
