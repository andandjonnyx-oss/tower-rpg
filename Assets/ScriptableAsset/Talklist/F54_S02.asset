  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3053\u304B\u3089\u306F\u65B0\u3057\u3044\u72B6\u614B\u7570\u5E38\u3001\n\u546A\u3044\u3068\u30AC\u30E9\u30B9\u304C\u51FA\u3066\u304F\u308B\u305C\u3002"
