    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4FBF\u5B9C\u4E0A\u9B54\u6CD5\u5C5E\u6027\u3068\u304B\u7269\u7406\u5C5E\u6027\u3068\u304B\u8A00\u3063\u3066\u308B\u304C\u3001\n\u5B9F\u969B\u306B\u306F\u6BB4\u5C5E\u6027\u9B54\u6CD5\u3068\u304B\u3001\u706B\u5C5E\u6027\u7269\u7406\u3068\u304B\u3001\n\u8272\u3005\u3042\u308B\u304B\u3089\u7D1B\u3089\u308F\u3057\u3044\u3093\u3060\u3088\u306A\u2026\u2026"
