  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30EB\u30FC\u30DA\u306F\u6301\u3063\u3066\u308B\u304B\uFF1F\n\u6575\u306EHP\u304C\u30D0\u30FC\u3067\u8868\u793A\u3055\u308C\u308B\u4FBF\u5229\u30A2\u30A4\u30C6\u30E0\u3060\uFF01\n\u62FE\u3048\u3066\u306A\u304F\u3066\u3082\u3053\u306E\u4F1A\u8A71\u306E\u6700\u5F8C\u306B\u8CB0\u3048\u308B\u304B\u3089\u5B89\u5FC3\u3057\u308D\u3088\uFF01"
