    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u843D\u3068\u3057\u7269\u3060\u3063\u3066\u3001\u304A\u524D\u306E\u843D\u3068\u3057\u7269\u3067\u3042\u3063\u3066\u3001\n\u79C1\u304C\u30D7\u30EC\u30BC\u30F3\u30C8\u3057\u305F\u8A33\u3058\u3083\u306A\u3044\u3093\u3060\u308D\uFF1F\n\u79C1\u3092\u8CAC\u3081\u308B\u306E\u306F\u304A\u9580\u9055\u3044\u3063\u3066\u3082\u3093\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3042\u3001\u3061\u306A\u307F\u306B\u3053\u306E\u907F\u96F7\u91DD\u3001\u3053\u306E\u30A4\u30D9\u30F3\u30C8\u9650\u5B9A\u3060\u304B\u3089\u3002\n\u4E8C\u5EA6\u3068\u624B\u306B\u5165\u3089\u306A\u3044\u304B\u3089\u3002\u6368\u3066\u3061\u3083\u3063\u305F\u3001\u3063\u3066\u4EBA\u306E\u305F\u3081\u306B\n\u3082\u30461\u3064\u3084\u308B\u3088\u3002\u5F8C\u534A\u5F79\u7ACB\u3064\u304B\u3082\u3088\uFF1F"
