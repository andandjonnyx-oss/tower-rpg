  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u2026\u2026\u306A\u3093\u3060\u3088\u3001\u305D\u306E\u76EE\u306F\u3002\n\u5225\u306B\u79C1\u5618\u306F\u3064\u3044\u3066\u306A\u3044\u305E\uFF1F\n\u30DC\u30B9\u306E\u540D\u524D\u306F\u300E\u3055\u3093\u3060\u30FC\u30C9\u30E9\u30B4\u30F3\u300F\u3060\u3063\u3066\u8A00\u3063\u305F\u3060\u3051\u3060\u308D\uFF1F"
