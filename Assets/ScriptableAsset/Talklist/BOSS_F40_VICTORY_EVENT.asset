  id: BOSS_F40_VICTORY_EVENT
  zukanTitle: "\u53EF\u611B\u304C\u3063\u3066\u3042\u3052\u3066\u306D"
  floor: 0
  step: 0
  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3042\u30FC\u3088\u304B\u3063\u305F\u3002\u307B\u3089\u3001\u30A8\u30DF\u30EA\u30FC\u3061\u3083\u3093\u3001\u3053\u3063\u3061\u304A\u3044\u3067\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: '-'
    text: "\u30A8\u30DF\u30EA\u30FC\u3068\u547C\u3070\u308C\u305F\u732B\u306F\u3001\u30D5\u30A7\u30B4\u30FC\u30EB\u306E\u65B9\u306B\u306F\u884C\u304B\u305A\u3001\nYou\u306E\u8DB3\u5143\u3067\u5BDD\u3053\u308D\u3093\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u306A\u3001\u4F55\u6545\u3060\u30A8\u30DF\u30EA\u30FC\u3061\u3083\u3093\uFF01\u3000\u4E00\u56DE\u990C\u3092\u3084\u3063\u305F\u3060\u3051\u306E\u305D\u306E\u7537\u306B\uFF01\n\u306F\uFF01\u3000\u305D\u3046\u304B\u3001\u30A8\u30DF\u30EA\u30FC\u3061\u3083\u3093\u306F\u30E1\u30B9\u732B\u3060\u304B\u3089\u30AA\u30B9\u306B\u5A9A\u3073\u308B\u306E\u304B\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3075\u3093\uFF01\u3000\u79C1\u3092\u88CF\u5207\u3063\u305F\u732B\u306A\u3093\u3066\u3082\u3046\u3044\u3089\u306A\u3044\u304B\u3089\u304F\u308C\u3066\u3084\u308B\u3002\n\u79C1\u306F\u5225\u306E\u732B\u3092\u4F5C\u308D\u3046\u3063\u3068\u3002\u30DE\u30F3\u30C1\u30AB\u30F3\u3063\u3066\u306E\u306B\u3057\u3088\u3046\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u3053\u306E\u732B\u3069\u3046\u3059\u308C\u3070\u3044\u3044\u3093\u3060\u3088\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
