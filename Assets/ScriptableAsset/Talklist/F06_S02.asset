  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3053\u304B\u3089\u306F\u66F4\u306B\u5F37\u3044\u6575\u304C\u51FA\u3066\u6765\u308B\u305E\uFF01\n\u30A2\u30A4\u30C6\u30E0\u904B\u306B\u6075\u307E\u308C\u305A\u5BFE\u7B56\u30A2\u30A4\u30C6\u30E0\u62FE\u3048\u306A\u304F\u3066\u3082\n\u3081\u3052\u305A\u306B\u4F55\u5EA6\u3082\u6F5C\u308D\u3046\u305C\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u305A\u306F\u30DD\u30A4\u30BA\u30F3\u30B9\u30E9\u30A4\u30E0\u3060\uFF01\n\u540D\u524D\u306E\u901A\u308A\u6BD2\u3070\u304B\u308A\u4ED8\u4E0E\u3057\u3066\u304F\u308B\u305E\uFF01\n\u8010\u6027\u30A2\u30A4\u30C6\u30E0\u304C\u6B32\u3057\u3044\u306A\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B21\u306B\u706B\u708E\u653E\u5C04\u5668\u3060\uFF01\n\u3072\u305F\u3059\u3089\u706B\u3092\u5674\u3044\u3066\u304F\u308B\u305E\uFF01\n\u786C\u3044\u3051\u3069\u5F31\u70B9\u306F\u3042\u308B\u306F\u305A\u3060\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6700\u5F8C\u306B1%\u3067999\u30C0\u30E1\u30FC\u30B8\u304F\u3093\u3060\uFF01\n\u51FA\u30AA\u30C1\u306B\u3082\u7A0B\u304C\u3042\u308B\u306A\uFF01\n\u304A\u524D\u306A\u30891%\u3092\u5F15\u3044\u3066\u304F\u308C\u308B\u3068\u4FE1\u3058\u3066\u308B\u305C\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "1\u968E\u304B\u30895\u968E\u3067\u306F\u6240\u6301\u3057\u3066\u3044\u308B\u3068\n\u300E\u30D2\u30FC\u30EB\u300F\u304C\u4F7F\u3048\u308B\u9B54\u5C0E\u66F8\uFF1F\u7684\u306A\u30A2\u30A4\u30C6\u30E0\u304C\u62FE\u3048\u308B\u3093\u3060\u304C\u3001\n\u307E\u3060\u62FE\u3048\u3066\u7121\u304B\u3063\u305F\u3089\u53EF\u54C0\u60F3\u3060\u304B\u3089\u3084\u308B\u3088\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
  rewardItem: {fileID: 11400000, guid: 3f3de5791f00e2a4d9777d17689e34f5, type: 2}
