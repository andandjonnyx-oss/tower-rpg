  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305F\u3060\u3001DEX\u306F\u547D\u4E2D\u529B\u306E\u4ED6\u306B\u3082\u3001\u56DE\u907F\u7387\u3068\u30AF\u30EA\u30C6\u30A3\u30AB\u30EB\u7387\u306B\n\u305D\u3053\u305D\u3053\u8CA2\u732E\u3059\u308B\u3002\u3068\u3044\u3063\u3066\u3082\u300120\u30671%\u3060\u3057\u3001\n\u6575\u306E\u547D\u4E2D\u7387\u3082\u6700\u4F4E\u4FDD\u8A3C\u304C10%\u3042\u308B\u3093\u3060\u3051\u3069\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305D\u308C\u3067\u3082\u7D42\u76E4\u306B\u306A\u308C\u3070\u3001\u81EA\u7136\u3068\u56DE\u907F\u7387\u3068\u30AF\u30EA\u30C6\u30A3\u30AB\u30EB\u7387\u306F\n\u7D50\u69CB\u306A\u3082\u3093\u306B\u306A\u308B\u3068\u601D\u3046\u305C\u3002\u3068\u306F\u3044\u3048\u3001\u6975\u632F\u308A\u3057\u305F\u3089\n\u4ED6\u306E\u30B9\u30C6\u30FC\u30BF\u30B9\u304C\u4F4E\u3059\u304E\u3066\u304D\u3064\u3044\u3068\u601D\u3046\u304C\u2026\u2026"
