  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3069\u308C\u3060\u3051\u547D\u4E2D\u529B\u3092\u4E0A\u3052\u3066\u3082\u3001\u6B66\u5668\u3084\u30B9\u30AD\u30EB\u306E\u57FA\u790E\u547D\u4E2D\u3092\u8D85\u3048\u308B\u4E8B\u306F\u7121\u3044\u305C\u3002"
