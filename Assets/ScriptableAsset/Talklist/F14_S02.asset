  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3053\u304B\u3089\u72B6\u614B\u7570\u5E38\u304C3\u3064\u3082\u5897\u3048\u308B\u305C\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u305A\u306F\u9EBB\u75FA\u3002\u304A\u524D\u3082\u6575\u3082\u300120%\u3067\u884C\u52D5\u30AD\u30E3\u30F3\u30BB\u30EB\u3060\u3002\n\u3064\u3044\u3067\u306B\u5854\u3092\u9032\u3080\u6642\u306B1\u79D2\u5F85\u305F\u3055\u308C\u308B\u3088\u3046\u306B\u306A\u308B\u3002\n\u3069\u3046\u3067\u3082\u3044\u3044\u30EA\u30A2\u30EA\u30C6\u30A3\u3063\u3066\u3084\u3064\u3060\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B21\u306B\u6697\u95C7\u3002\u304A\u524D\u306E\u5834\u5408\u306F\u3001\u6575\u306E\u56DE\u907F\u529B\u304C\u500D\u306B\u306A\u308B\u3002\n\u6575\u306E\u5834\u5408\u306F\u3001\u547D\u4E2D\u7387\u304C\u534A\u5206\u306B\u306A\u308B\u3002\n\u3064\u3044\u3067\u306B\u5854\u3092\u9032\u3080\u3068\u304D\u80CC\u666F\u304C\u771F\u3063\u9ED2\u306B\u306A\u308B\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6700\u5F8C\u306B\u6012\u308A\u3002\u3053\u308C\u306F\u30D0\u30D5\u306E\u3088\u3046\u306A\u3082\u306E\u3067\u3001\n\u653B\u6483\u529B\u304C1.5\u500D\u306B\u306A\u308B\u4EE3\u308F\u308A\u306B\u901A\u5E38\u653B\u6483\u3057\u304B\u51FA\u6765\u306A\u304F\u306A\u308B\u3002\n\u6575\u3082\u884C\u52D5\u304C\u56FA\u5B9A\u3055\u308C\u308B\u305E\u3002\u4F7F\u3044\u3069\u3053\u308D\u306B\u60A9\u3080\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6025\u306B3\u3064\u3082\u72B6\u614B\u7570\u5E38\u3092\u8FFD\u52A0\u3057\u305F\u3082\u3093\u3060\u304B\u3089\u3001\n\u3057\u3070\u3089\u304F\u305D\u308C\u95A2\u4FC2\u306E\u30A2\u30A4\u30C6\u30E0\u3070\u304B\u308A\u51FA\u308B\u3051\u3069\u6C17\u306B\u3059\u308B\u306A\u3088\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
