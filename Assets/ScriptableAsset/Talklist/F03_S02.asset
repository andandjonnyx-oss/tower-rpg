  id: F03_S02
  floor: 3
  step: 2
  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u306E\u5854\u306B\u3042\u308B\u30A2\u30A4\u30C6\u30E0\u3082\u30E2\u30F3\u30B9\u30BF\u30FC\u3082\u3001\u5168\u90E8\u79C1\u306E\u9B54\u529B\u3067\u4F5C\u3063\u3066\u308B\u3093\u3060\u305C\uFF01\n\u5854\u306B\u5165\u3063\u305F\u6642\u306B\u3044\u3064\u306E\u307E\u306B\u304B\u6301\u3063\u3066\u305F\u5263\u3084\u85AC\u8349\u3082\u306A\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u2026\u2026\u4F55\uFF1F\u3000\u30B2\u30FC\u30E0\u30B9\u30BF\u30FC\u30C8\u76F4\u5F8C\u306B\u5009\u5EAB\u306B\u884C\u3063\u3066\u3001\n\u305D\u3053\u3067\u30A2\u30A4\u30C6\u30E0\u3092\u5168\u90E8\u6368\u3066\u305F\u304B\u3089\u5854\u306B\u5165\u3063\u305F\u6642\u306B\u4F55\u3082\u7121\u3044\u3063\u3066\uFF1F\n\u3084\u3081\u308D\u3088\u3001\u305D\u3046\u3044\u3046\u91CD\u7BB1\u306E\u9685\u3092\u7A81\u304F\u30D7\u30EC\u30A4\u306F\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u305F\u307E\u306B\u30A2\u30F3\u30BF\u304C\u4F55\u3092\u8A00\u3063\u3066\u3044\u308B\u306E\u304B\u7406\u89E3\u3067\u304D\u306A\u3044\u3093\u3060\u304C\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3063\u3061\u306E\u8A71\u3060\u3001\u6C17\u306B\u3059\u308B\u306A\u3002\n\u3068\u306B\u304B\u304F\u30A2\u30A4\u30C6\u30E0\u3082\u30E2\u30F3\u30B9\u30BF\u30FC\u3082\u3001\u79C1\u304C\u5B9F\u7269\u3092\u771F\u4F3C\u3066\u4F5C\u3063\u305F\u507D\u7269\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4ECA\u5F8C\u4EBA\u578B\u306E\u6575\u304C\u51FA\u3066\u6765\u3066\u3082\u6C17\u306B\u3059\u308B\u4E8B\u306F\u7121\u3044\u3057\u3001\n\u300E\u30EC\u30A2\u306A\u88C5\u5099\u624B\u306B\u5165\u3063\u305F\u3057\u5225\u306E\u30C0\u30F3\u30B8\u30E7\u30F3\u653B\u7565\u3057\u3088\u3046\u3063\u3068\u300F\n\u306A\u3093\u3066\u7121\u99C4\u3060\u305E\u3002\u7DAD\u6301\u306B\u3082\u9650\u754C\u304C\u3042\u308B\u304B\u3089\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u304A\u524D\u304C\u4ECA\u62E0\u70B9\u3068\u3057\u3066\u4F7F\u3063\u3066\u308B\u5BBF\u5C4B\u304F\u3089\u3044\u306A\u3089\u554F\u984C\u7121\u3044\u304C\u3001\n\u753A\u3092\u51FA\u3066\u3061\u3087\u3063\u3068\u96E2\u308C\u305F\u3089\u9014\u7AEF\u306B\u6D88\u6EC5\u3060\u3002\n\u3053\u3053\u3067\u624B\u306B\u5165\u308C\u305F\u93A7\u306A\u3093\u3066\u7740\u3066\u305F\u3089\u3059\u3063\u307D\u3093\u307D\u3093\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u2026\u2026\u3053\u3053\u3067\u624B\u306B\u5165\u308C\u305F\u30A2\u30A4\u30C6\u30E0\u3092\u3001\u753A\u3067\u58F2\u3063\u305F\u3089\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3084\u3081\u308D\u3088\u3001\u305D\u3046\u3044\u3046\u306E\u306F\u2026\u2026\n\u203B\u3053\u306E\u30B2\u30FC\u30E0\u306B\u304A\u91D1\u306E\u6982\u5FF5\u306F\u3042\u308A\u307E\u305B\u3093"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3042\u3068\u3001\u300E\u3084\u3089\u308C\u305F\u3089\u4F55\u6545\u304B\u5BBF\u5C4B\u306B\u623B\u3063\u3066\u308B\u300F\u3063\u3066\u73FE\u8C61\u3082\u3001\n\u5854\u306B\u5165\u3063\u305F\u6642\u70B9\u3067\u304A\u524D\u306E\u8089\u4F53\u3068\u7CBE\u795E\u304C\u5206\u96E2\u3057\u3066\u3001\n\u3084\u3089\u308C\u305F\u3089\u79C1\u304C\u5BBF\u5C4B\u306B\u8089\u4F53\u3092\u9001\u308A\u5C4A\u3051\u3066\u308B\u304B\u3089\u306A\u3093\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4ECA\u558B\u3063\u3066\u3044\u308B\u304A\u524D\u306F\u3044\u308F\u3070\u507D\u7269\u3067\u3001\n\u672C\u7269\u306E\u304A\u524D\u306F\u5854\u306E\u5165\u53E3\u3067\u9B42\u306E\u629C\u3051\u6BBB\u72B6\u614B\u3060\uFF01\n\u3060\u304B\u3089\u3044\u304F\u3089\u50B7\u3064\u3044\u3066\u3082\u5B89\u5FC3\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u5168\u7136\u5B89\u5FC3\u51FA\u6765\u306A\u3044\u8AAC\u660E\u306A\u3093\u3060\u304C\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
  rewardItem: {fileID: 0}
