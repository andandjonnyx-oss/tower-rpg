  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "MP\u4E0D\u8DB3\u3092\u5B9F\u611F\u3057\u3066\u3001\u305D\u308D\u305D\u308DINT\u306B\u3082\u632F\u308A\u59CB\u3081\u305F\u304B\uFF1F\nMP\u56DE\u5FA9\u30A2\u30A4\u30C6\u30E0\u304C\u7121\u99C4\u306B\u306A\u3089\u306A\u3044\u7A0B\u5EA6\u306B\u306F\u6B32\u3057\u3044\u3088\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u9B54\u6CD5\u653B\u6483\u3068\u9B54\u6CD5\u9632\u5FA1\u3082\u4E0A\u304C\u308B\u3093\u3060\u304C\u3001\n\u6B63\u76F4\u307B\u3068\u3093\u3069\u306E\u653B\u6483\u9B54\u6CD5\u306F\u5A01\u529B\u56FA\u5B9A\u3060\u304B\u3089\u3001\n\u9B54\u6CD5\u653B\u6483\u3092\u4F7F\u308F\u306A\u3044\u3093\u3060\u3088\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305D\u306E\u5206\u9B54\u6CD5\u653B\u6483\u3092\u53C2\u7167\u3059\u308B\u9B54\u6CD5\u306F\u3001\n\u9B54\u6CD5\u653B\u6483\xD710\u500D\u3068\u304B\u3001\u500D\u7387\u306F\u304B\u306A\u308A\u9AD8\u3081\u3060\u305C\u3002\n\u71C3\u8CBB\u3082\u60AA\u3044\u3057\u4E0A\u3052\u308B\u30A2\u30A4\u30C6\u30E0\u3082\u5C11\u306A\u3044\u304C\u3001\u5F8C\u534A\u306B\u306A\u308B\u3068\u899A\u9192\u3059\u308B\u304B\u3082\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
