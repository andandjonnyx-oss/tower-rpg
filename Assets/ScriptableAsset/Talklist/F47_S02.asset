    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u52D8\u306E\u3044\u3044\u304A\u524D\u306A\u3089\u308F\u304B\u3063\u3066\u308B\u3088\u306A\uFF1F\n\u3064\u307E\u308A\u4ECA\u5F8C\u306F\u3001\u6575\u3082\u5FC5\u4E2D\u6280\u3092\u4F7F\u3046\u3063\u3066\u3053\u3068\u3060\u3002\n\u56DE\u907F\u7279\u5316\u30D3\u30EB\u30C9\u304C\u5D29\u58CA\u3059\u308B\u306A\uFF1F"
