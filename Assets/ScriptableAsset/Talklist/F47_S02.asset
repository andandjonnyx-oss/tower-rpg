  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u306E\u8FBA\u306B\u843D\u3061\u3066\u3044\u308B\u3001\u30E8\u30B1\u30EB\u30CA\u30F3\u3063\u3066\u9B54\u6CD5\u306F\u3001\n\u6575\u306E\u56DE\u907F\u7387\u3092\u5927\u5E45\u306B\u4E0B\u3052\u308B\u3093\u3060\u304C\u3001\n\u305D\u306E\u9B54\u6CD5\u81EA\u4F53\u304C\u907F\u3051\u3089\u308C\u305F\u3089\u30A6\u30B6\u30A4\u3088\u306A\u3002"
