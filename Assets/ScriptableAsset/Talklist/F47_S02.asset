  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3060\u304B\u3089\u3001\u3053\u306E\u9B54\u6CD5\u306F\u5FC5\u4E2D\u306B\u3057\u3066\u3044\u308B\u3002\n\u6575\u306E\u56DE\u907F\u3060\u3068\u304B\u6697\u95C7\u3060\u3068\u304B\u5168\u90E8\u7121\u8996\u3060\u3002"
