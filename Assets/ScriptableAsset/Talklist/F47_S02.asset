  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u306E\u8FBA\u306B\u843D\u3061\u3066\u3044\u308B\u3001\u30E8\u30B1\u30EB\u30CA\u30F3\u3063\u3066\u9B54\u6CD5\u306F\u3001\n\u6575\u306E\u56DE\u907F\u7387\u3092\u5927\u5E45\u306B\u4E0B\u3052\u308B\u3093\u3060\u304C\u3001\n\u305D\u306E\u9B54\u6CD5\u81EA\u4F53\u304C\u907F\u3051\u3089\u308C\u305F\u3089\u30A6\u30B6\u30A4\u3088\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3060\u304B\u3089\u3001\u3053\u306E\u9B54\u6CD5\u306F\u307B\u307C\u5FC5\u4E2D\u306B\u3057\u3066\u3044\u308B\u3002\n\u5927\u62B5\u306E\u6280\u306E\u57FA\u790E\u547D\u4E2D\u306F95\u3068\u304B\u3067\u3001\n\u305D\u308C\u306B\u56DE\u907F\u7387\u304C\u7D61\u3093\u3067\u6765\u308B\u3093\u3060\u304C\u3001"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u306E\u57FA\u790E\u547D\u4E2D\u304C\u4F8B\u3048\u30701000\u3068\u304B\u306B\u306A\u308B\u3068\u3001\n\u6575\u306E\u56DE\u907F\u7387\u304C90%\u306B\u306A\u3063\u3066\u3044\u305F\u3068\u3057\u3066\u3082\u3001\n\u547D\u4E2D\u304C100\u306B\u306A\u308B\u3063\u3066\u8A33\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3060\u304B\u3089\u307B\u307C\u5FC5\u4E2D\u6280\u306E\u57FA\u790E\u547D\u4E2D\u306F\u30AC\u30AD\u304C\u8003\u3048\u305F\u307F\u305F\u3044\u306A\u5024\u306B\u3057\u3066\u308B\u3002\n\u305D\u308C\u3067\u3082"
