    text: "\u30AC\u30F3\u30AC\u30F3\u9032\u3093\u3067\uFF01\n\u30AC\u30F3\u30AC\u30F3\u3084\u3089\u308C\u3066\uFF01\n\u30AC\u30F3\u30AC\u30F3\u7A3C\u3050\uFF01"
