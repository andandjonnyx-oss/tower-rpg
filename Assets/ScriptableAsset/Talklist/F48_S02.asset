  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u5F8C\u534A\u306E\u6575\u306F\u80FD\u529B\u3084\u30B9\u30AD\u30EB\u304C\u5F37\u529B\u306A\u306E\u3082\u3042\u308B\u304C\u3001\n\u3044\u308F\u3086\u308B\u8CE2\u3055\u3063\u3066\u306E\u3082\u3042\u308B\u305C\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4F8B\u3048\u3070\u3053\u3053\u3089\u306B\u51FA\u3066\u6765\u308B\u30C8\u30EA\u30D7\u30EB\u30DE\u30FC\u30B8\u6539\u306F\u3001\n30\uFF05\u3067\u9B54\u6CD5\u9632\u5FA1\u306E\u30C7\u30D0\u30D5\u3092\u4F7F\u3063\u3066\u6765\u308B\u3002\n\u305F\u3060\u3001\u3053\u306E\u6280\u306F\u304A\u524D\u304C\u65E2\u306B\u30C7\u30D0\u30D5\u72B6\u614B\u3060\u3068\u4F7F\u308F\u306A\u3044\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30B5\u30A4\u30B3\u30ED\u3092\u632F\u3063\u3066\u3053\u306E\u6280\u304C\u9078\u3070\u308C\u3066\u3082\u3001\n\u518D\u62BD\u9078\u3055\u308C\u308B\u304B\u3089\u7D50\u5C40\u306F70\uFF05\u3082\u3042\u308B\u30C8\u30EA\u30D7\u30EB\u30DE\u30B8\u30C3\u30AF\u304C\n\u9B54\u6CD5\u9632\u5FA1\u4F4E\u3044\u72B6\u614B\u3067\u98DB\u3093\u3067\u304F\u308B\u3063\u3066\u8A33\u3088\u3002\n\u3084\u3063\u3066\u3089\u3093\u306A\u3044\u306A\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3061\u306A\u307F\u306B\u518D\u62BD\u9078\u306E\u9650\u5EA6\u306F10\u56DE\u3060\u3002\n\u7121\u99C4\u884C\u52D5\u3092\u5ACC\u3044\u3059\u304E\u3066\u7121\u9650\u30EB\u30FC\u30D7\u306B\u306A\u3063\u305F\u3089\u610F\u5473\u7121\u3044\u304B\u3089\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
