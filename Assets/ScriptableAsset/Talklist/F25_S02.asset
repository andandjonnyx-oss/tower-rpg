    text: "\u306F\u30FC\u3001\u3084\u3063\u3068\u6C88\u9ED9\u6CBB\u3063\u305F\u3002\n\u5B9F\u306F\u79C1\u3001\u3053\u3046\u898B\u3048\u3066\u6C88\u9ED9\u306B\u5B8C\u5168\u8010\u6027\u6301\u3063\u3066\u306D\u30FC\u3093\u3060\u308F\u3002\n\u307E\u3041\u3001\u305D\u308C\u3067\u30828\u5272\u306F\u8010\u6027\u3042\u308B\u3057\u7269\u7406\u3082\u9B54\u6CD5\u3082\u30D0\u30E9\u30F3\u30B9\u826F\u304F\u4F7F\u3046\u304B\u3089\n\u6226\u3046\u6642\u306B\u6C88\u9ED9\u72D9\u3046\u306E\u306F\u5F97\u7B56\u3058\u3083\u306A\u3044\u3068\u601D\u3046\u3051\u3069\u306A\uFF1F"
