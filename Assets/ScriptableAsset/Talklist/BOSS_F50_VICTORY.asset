    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3055\u3001\u30B7\u30EA\u30A2\u30B9\u306A\u30D1\u30FC\u30C8\u306F\u3082\u3046\u7D42\u308F\u308A\u3002\n2STEP\u9032\u3093\u3060\u3089\u3044\u3064\u3082\u306E\u30B3\u30DF\u30AB\u30EB\u306A\u30D1\u30FC\u30C8\u304C\u7D9A\u304F\u305C\u3002"
