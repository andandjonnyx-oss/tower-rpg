  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u2026\u2026\u8155\u3092\u4E0A\u3052\u305F\u306A\u3002\n\u5408\u683C\u3060\u3002\u3053\u306E\u5148\u306B\u9032\u3080\u4E8B\u3092\u8A31\u53EF\u3059\u308B\u3002"
