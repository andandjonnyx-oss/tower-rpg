  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4E88\u60F3\u5916\u306B\u5F37\u304F\u3066\u3073\u3063\u304F\u308A\u3057\u305F\u304B\uFF1F\n100\u968E\u3067\u6226\u3046\u79C1\u306F\u3053\u306E\u6570\u500D\u306F\u5F37\u3044\u305E\uFF1F"
