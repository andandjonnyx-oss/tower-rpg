  - speaker: You
    text: "\u306F\u3041\u2026\u2026\u306F\u3041\u2026\u2026\n\uFF08\u3053\u308C\u3067\u5168\u7136\u672C\u6C17\u3058\u3083\u306A\u3044\u306E\u304B\u3088\u3001\u6B63\u76F4\u8210\u3081\u3066\u305F\u2026\u2026\uFF09"
