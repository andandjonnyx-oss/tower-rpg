  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3042\u30FC\u8179\u6E1B\u3063\u305F\u3002\u3061\u3087\u3063\u3068\u98EF\u5BC4\u8D8A\u305B\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: '-'
    text: "\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u52DD\u624B\u306BYou\u306E\u9053\u5177\u888B\u3092\u6F01\u308A\u3001\n\u96A0\u3057\u6301\u3063\u3066\u3044\u305F\u51B7\u51CD\u30DE\u30B0\u30ED\u3092\u98DF\u3079\u3066\u3057\u307E\u3063\u305F\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u306A\u3093\u3067\u305D\u3093\u306A\u3082\u306E\u3092\u96A0\u3057\u6301\u3063\u3066\u3093\u3060\u2026\u2026\n\u6575\u304C\u30A2\u30A4\u30C6\u30E0\u3092\u98DF\u3046\u6642\u306F\u3001\u6D88\u8CBB\u30A2\u30A4\u30C6\u30E0\u3060\u3051\u304C\u30BF\u30FC\u30B2\u30C3\u30C8\u3060\u3002\n\u3060\u304B\u3089\u51B7\u51CD\u30DE\u30B0\u30ED\u307F\u305F\u3044\u306A\u300C\u98DF\u3079\u3089\u308C\u308B\u6B66\u5668\u300D\u306F\u72D9\u308F\u308C\u306A\u3044\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3064\u3044\u3067\u306B\u3001\u4F7F\u3044\u6368\u3066\u30E9\u30A4\u30D5\u30EB\u307F\u305F\u3044\u306A\u3001\n\u4F7F\u3063\u305F\u5F8C\u306B\u5225\u306E\u30A2\u30A4\u30C6\u30E0\u306B\u5909\u5316\u3059\u308B\u30A2\u30A4\u30C6\u30E0\u3092\u98DF\u308F\u308C\u3066\u3082\u3001\n\u5909\u5316\u5F8C\u306E\u30A2\u30A4\u30C6\u30E0\u306F\u8CB0\u3048\u306A\u3044\u3002\u5168\u90E8\u6D88\u5316\u3055\u308C\u3061\u307E\u3046\u304B\u3089\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u653B\u6483\u30A2\u30A4\u30C6\u30E0\u98DF\u3063\u305F\u3089\u81EA\u6EC5\u3059\u308B\u3068\u306F\u3044\u3048\u3001\n\u30A2\u30A4\u30C6\u30E0\u3092\u4E88\u5B9A\u5916\u306E\u30BF\u30A4\u30DF\u30F3\u30B0\u3067\u5931\u3046\u306E\u306F\u75DB\u3044\u304B\u3089\u306A\u3002\n\u3055\u3063\u3055\u3068\u7247\u4ED8\u3051\u3066\u304A\u304D\u305F\u3044\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
