  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4E45\u3005\u306B\u6311\u6226\u8005\u3082\u6765\u3066\u3001\u307F\u3093\u306A\u5FD9\u3057\u3044\u304B\u3089\u3055\u3001\n\u30C7\u30AD\u308B\u4E0A\u53F8\u3068\u3057\u3066\u52B4\u3044\u306E\u305F\u3081\u306B\u98DF\u4E8B\u306B\u8A98\u3063\u305F\u3093\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u713C\u8089\u3067\u6C7A\u8D77\u96C6\u4F1A\u3057\u3088\u3046\u3068\u601D\u3063\u305F\u3093\u3060\u3051\u3069\u3055\u3001\n\u30CF\u30FC\u30D4\u30FC\u3068\u30DF\u30CE\u30BF\u30A6\u30EB\u30B9\u3068\u30A2\u30EB\u30E9\u30A6\u30CD\u304C\u3044\u305F\u304B\u3089\u3001\n\u9D8F\u8089\u3082\u725B\u8089\u3082\u91CE\u83DC\u3082\u98DF\u3079\u3065\u3089\u304F\u3066\u3055\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u7D50\u5C40\u3072\u305F\u3059\u3089\u8C5A\u8089\u3092\u713C\u3044\u3066\u98DF\u3046\u3068\u3044\u3046\n\u80C3\u3082\u305F\u308C\u3057\u305D\u3046\u306A\u98DF\u4E8B\u4F1A\u306B\u306A\u3063\u3061\u307E\u3063\u305F\u3088\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u3060\u3053\u306E\u5C64\u306F\u30DE\u30B7\u306A\u65B9\u3060\u305C\uFF1F\u3000\u7D42\u76E4\u306B\u306A\u308B\u3068\u3001\n\u8272\u3093\u306A\u5B97\u6559\u306E\u795E\u3005\u3068\u304B\u3082\u51FA\u3066\u6765\u308B\u304B\u3089\u3001\n\u7981\u5FCC\u304C\u3069\u3093\u3069\u3093\u7D61\u3093\u3067\u6765\u308B\u3002\u4E0A\u53F8\u3082\u5927\u5909\u3060\u305C\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
