    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u304A\u524D\u3001\u5973\u306E\u5B50\u304C\u98DF\u3079\u305F\u30A2\u30A4\u30B9\u306E\u68D2\u3092\u5E73\u7136\u3068\u8981\u6C42\u3059\u308B\u306A\u3088\u2026\u2026\n\u3057\u3087\u3046\u304C\u306A\u3044\u304B\u3089\u30B9\u30C6\u30FC\u30BF\u30B9\u30A2\u30C3\u30D7\u3092\u3084\u308B\u3088\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3061\u306A\u307F\u306B\u30DB\u30EF\u30A4\u30C8\u30E2\u30F3\u30D6\u30E9\u30F3\u306F\u30B8\u30D1\u30F3\u30B0\u306E\u304A\u83D3\u5B50\u306A\u3093\u3060\u3051\u3069\u3001\n\u30B8\u30D1\u30F3\u30B0\u306E\u65B9\u3067\u3082\u897F\u3067\u3057\u304B\u58F2\u3063\u3066\u306A\u3044\u3089\u3057\u3044\u305C\u3002"
