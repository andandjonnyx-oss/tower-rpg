  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u79C1\u3060\uFF01\u3000\u52FF\u8AD6100\u968E\u3067\u6226\u3046\u6642\u3088\u308A\u3082\u9065\u304B\u306B\u5F31\u3044\u3051\u3069\u3001\n\u884C\u52D5\u30D1\u30BF\u30FC\u30F3\u306F\u540C\u3058\u3060\u304B\u3089\u306A\u3001\u4E88\u7FD2\u3057\u3066\u304A\u3051\u3088\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4ECA\u307E\u3067\u306E\u30DC\u30B9\u3068\u306F\u683C\u304C\u9055\u3046\u305E\uFF1F\n\u2026\u202630\u968E\u306E\u30DC\u30B9\u308240\u968E\u306E\u30DC\u30B9\u3082\u7279\u6B8A\u904E\u304E\u308B\u304B\u3089\n\u3042\u3093\u307E\u308A\u5B9F\u611F\u304C\u6E67\u304B\u306A\u3044\uFF1F\u3000\u78BA\u304B\u306B\u306A\u2026\u2026"
