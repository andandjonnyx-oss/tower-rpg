  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3044\u3088\u3044\u3088\u3053\u306E\u8A66\u7DF4\u3068\u9858\u3044\u306E\u5854\u3082\u6298\u308A\u8FD4\u3057\u5730\u70B9\uFF01\n\u6C17\u306B\u306A\u308B\u7BC0\u76EE\u306E50\u968E\u306E\u30DC\u30B9\u306F\u2026\u2026"
