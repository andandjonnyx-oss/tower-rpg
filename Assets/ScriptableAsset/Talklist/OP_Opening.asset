  m_Script: {fileID: 11500000, guid: 3ceee631d66cb8040b25855261aedebc, type: 3}
  m_Name: OP_Opening
  m_EditorClassIdentifier: Assembly-CSharp::TalkEvent
  id: OP_Opening
  floor: 0
  step: 0
  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: '-'
    text: "\u8CB4\u65B9\u306F\u8272\u3005\u306A\u5834\u6240\u3092\u65C5\u3057\u3066\u3044\u308B\u5192\u967A\u8005\u306E\u7537\u3060\u3002\n\u3042\u308B\u65E5\u3001\u8CB4\u65B9\u306F\u5DE8\u5927\u306A\u5854\u3092\u898B\u3064\u3051\u3001\u305D\u3053\u3092\u76EE\u6307\u3059\u3053\u3068\u306B\u3057\u305F\u3002"
    portrait: {fileID: 0}
    backgroundOverride: {fileID: 0}
  - speaker: '-'
    text: "\u5854\u306E\u8FD1\u304F\u306B\u3042\u308B\u753A\u306B\u8FBF\u308A\u7740\u3044\u305F\u8CB4\u65B9\u306F\u3001\n\u753A\u4EBA\u306B\u5854\u306B\u3064\u3044\u3066\u805E\u3044\u3066\u307F\u308B\u3053\u3068\u306B\u3057\u305F\u3002"
    portrait: {fileID: 0}
    backgroundOverride: {fileID: 0}
  - speaker: "\u753A\u4EBA"
    text: "\u3042\u306E\u5854\u306F\u6570\u767E\u5E74\u524D\u304B\u3089\u5EFA\u3063\u3066\u3044\u308B\u3089\u3057\u3044\u3093\u3060\u3002\n\u306A\u3093\u3067\u3082\u9802\u4E0A\u306B\u884C\u3051\u3070\u9858\u3044\u304C\u53F6\u3046\u3089\u3057\u3044\u304C\u3001\n\u4E2D\u306B\u306F\u51F6\u60AA\u306A\u30E2\u30F3\u30B9\u30BF\u30FC\u304C\u3046\u308D\u3064\u3044\u3066\u3044\u3066\u5371\u967A\u3060\u304B\u3089\u884C\u304B\u306A\u3044\u65B9\u304C\u3044\u3044\u3002"
    portrait: {fileID: 0}
    backgroundOverride: {fileID: 0}
  - speaker: '-'
    text: "\u6570\u767E\u5E74\u524D\u306F\u5192\u967A\u8005\u9054\u304C\u5854\u306E\u9802\u4E0A\u3092\u76EE\u6307\u3057\u3066\u3044\u305F\u305D\u3046\u3060\u304C\u3001\n\u65E2\u306B\u5854\u306B\u5411\u304B\u3046\u4EBA\u304C\u3044\u306A\u304F\u306A\u3063\u3066\u767E\u5E74\u4EE5\u4E0A\u304C\u7D4C\u3064\u3089\u3057\u3044\u3002\n\u597D\u5947\u5FC3\u65FA\u76DB\u306A\u8CB4\u65B9\u306F\u8A66\u3057\u306B\u5854\u306E\u8FD1\u304F\u3078\u3068\u5411\u304B\u3046\u3002"
    portrait: {fileID: 0}
    backgroundOverride: {fileID: 0}
  - speaker: '-'
    text: "\u5854\u306B\u5411\u304B\u3046\u9053\u306E\u9014\u4E2D\u306B\u306F\u3001\u753A\u4EBA\u304C\u4F5C\u3063\u305F\u3068\u601D\u308F\u3057\u304D\u3001\n\u7ACB\u3061\u5165\u308A\u7981\u6B62\u306E\u7ACB\u3066\u770B\u677F\u304C\u58CA\u3055\u308C\u3066\u304A\u308A\u3001\n\u4EE3\u308F\u308A\u306B\u65B0\u3057\u3044\u7ACB\u3066\u770B\u677F\u3002"
    portrait: {fileID: 0}
    backgroundOverride: {fileID: 0}
  - speaker: '-'
    text: "\u5192\u967A\u8005\u5927\u6B53\u8FCE\uFF01\u3000\u89AA\u5207\u8A2D\u8A08\u3001\u30C7\u30B9\u30DA\u30CA\u7121\u3057\u306E\u308F\u304F\u308F\u304F\u30C0\u30F3\u30B8\u30E7\u30F3\uFF01\n\u4ECA\u306A\u3089\u306A\u3093\u3068\u7F8E\u5C11\u5973\u304C\u30A2\u30B7\u30B9\u30C8\u3057\u307E\u3059\uFF01"
    portrait: {fileID: 0}
    backgroundOverride: {fileID: 0}
  - speaker: '-'
    text: "\u80E1\u6563\u81ED\u3055\u3092\u611F\u3058\u306A\u304C\u3089\u3082\u3001\n\u8CB4\u65B9\u306F\u753A\u306E\u5BBF\u5C4B\u306E\u4E00\u5BA4\u3092\u62E0\u70B9\u3068\u3057\u3066\u501F\u308A\u3001\n\u5854\u3078\u3068\u5411\u304B\u3046\u306E\u3060\u3063\u305F\u30FB\u30FB\u30FB"
    portrait: {fileID: 0}
    backgroundOverride: {fileID: 0}
  conditions: []
  rewardItem: {fileID: 0}
