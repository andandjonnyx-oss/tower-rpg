  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4F8B\u3048\u3070CT5\u3042\u308B\u30B9\u30AD\u30EB\u3092\u4F7F\u3063\u3066\u3001\n\u305D\u306E\u6B21\u306E\u30BF\u30FC\u30F3\u3067\u306F\u3082\u30461\u3064\u3042\u308B\u305D\u306E\u88C5\u5099\u306B\u5909\u66F4\u3059\u308B\u3002\n\u3059\u308B\u3068\u30012\u30BF\u30FC\u30F3\u5F8C\u306B\u307E\u305F\u305D\u306E\u30B9\u30AD\u30EB\u304C\u4F7F\u3048\u308B\u3063\u3066\u8A33\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "20\u500B\u306E\u30A2\u30A4\u30C6\u30E0\u67A0\u3092\u540C\u3058\u6B66\u5668\u3067\u57CB\u3081\u308B\u3063\u3066\u306E\u306F\u3001\n\u62B5\u6297\u304C\u3042\u308B\u304B\u3082\u3057\u308C\u306A\u3044\u304C\u3001\u5F37\u6B66\u5668\u5F37\u30B9\u30AD\u30EB\u30B4\u30EA\u62BC\u3057\u6226\u6CD5\u3082\n\u306A\u304B\u306A\u304B\u5F37\u3044\u3068\u601D\u3046\u305C\uFF1F"
