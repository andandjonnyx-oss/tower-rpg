  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6226\u95D8\u4E2D\u306B\u6B66\u5668\u3092\u6301\u3061\u66FF\u3048\u3066\u308B\u304B\uFF1F\n\u30BF\u30FC\u30F3\u306F\u6D88\u8CBB\u3059\u308B\u3051\u3069\u3001\u88C5\u5099\u3092\u5165\u308C\u66FF\u3048\u3089\u308C\u308B\u305C\u3002"
