  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6575\u306B\u5408\u3063\u305F\u6B66\u5668\u3092\u7528\u610F\u3059\u308B\u3063\u3066\u306E\u3082\u3042\u308A\u3060\u3057\u3001\n\u540C\u3058\u6B66\u5668\u3092\u8907\u6570\u6301\u3064\u3053\u3068\u306B\u3082\u610F\u5473\u304C\u3042\u308B\u3002"
