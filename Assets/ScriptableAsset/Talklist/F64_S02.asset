  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4E45\u3005\u306B\u4E2D\u6575\u89E3\u8AAC\u3060\u3002\n\u4ECA\u307E\u3067\u72B6\u614B\u7570\u5E38\u306E\u89E3\u8AAC\u3068\u304B\u304C\u512A\u5148\u3055\u308C\u3061\u307E\u3063\u305F\u3051\u3069\u3001\n\u3053\u306E\u5C64\u306F\u65B0\u898F\u306E\u72B6\u614B\u7570\u5E38\u3068\u304B\u7121\u3044\u304B\u3089\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u305A\u306F\u30D0\u30C3\u30C8\u30AC\u30FC\u30EB\u3002\n\u304A\u6C7A\u307E\u308A\u306E\u6697\u95C7\u653B\u6483\u306B\u52A0\u3048\u3066\u3001\n\u5438\u8840\u3068\u8A00\u3046\u3053\u3068\u3067\u30C9\u30EC\u30A4\u30F3\u3082\u4F7F\u3046\u305E\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u7D9A\u3044\u3066\u30CD\u30B3\u30DE\u30BF\u3002HP\u306F\u4F4E\u3081\u3060\u304C\u3001\n\u3053\u306E\u8FBA\u3058\u3083\u5C48\u6307\u306E\u56DE\u907F\u529B\u3092\u8A87\u308B\u305C\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6700\u5F8C\u306B\u30B5\u30AD\u30E5\u30D0\u30B9\u3002\u3084\u3063\u3068\u672C\u7269\u304C\u767B\u5834\u3060\u3002\n\u30EC\u30D9\u30EB\u30C9\u30EC\u30A4\u30F3\u3068\u30C1\u30E3\u30FC\u30E0\u3092\u540C\u6642\u306B\u304B\u3051\u3066\u304F\u308B\u305E\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
