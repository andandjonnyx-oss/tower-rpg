  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "100\u30C0\u30E1\u304F\u3093\u306E\u6D17\u793C\u306F\u53D7\u3051\u305F\u304B\uFF1F\n\u5148\u5236\u653B\u6483\u81EA\u7206\u9632\u5FA1\u5B8C\u5168\u8CAB\u901A\u7121\u5C5E\u6027\u306F\u3001\n\u4F5C\u3063\u305F\u79C1\u304C\u8A00\u3046\u306E\u3082\u306A\u3093\u3060\u3051\u3069\u3001\u5ACC\u304C\u3089\u305B\u3060\u3088\u306A\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u3041\u3001\u666E\u6BB5\u306F\u7D76\u5BFE\u306B\u304A\u524D\u304C\u5148\u5236\u53D6\u308C\u308B\u3057\u3001\n\u5F37\u529B\u306A\u30B9\u30AD\u30EB\u30921\u30BF\u30FC\u30F3\u76EE\u306B\u4F7F\u3048\u308B\u8A33\u3060\u304B\u3089\u3001\n\u6C17\u3092\u60AA\u304F\u3057\u306A\u3044\u3067\u6B32\u3057\u3044\u3093\u3060\u304C\u2026\u2026"
