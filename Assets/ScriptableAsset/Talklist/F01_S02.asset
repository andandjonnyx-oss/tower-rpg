  id: F01_S02
  zukanTitle: "\u3088\u3046\u3053\u305D\u8A66\u7DF4\u3068\u9858\u3044\u306E\u5854\u3078"
  floor: 1
  step: 2
  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3088\u3046\u3053\u305D\u8A66\u7DF4\u3068\u9858\u3044\u306E\u5854\u3078\uFF01\uFF01\uFF01\uFF01\n\u3053\u308C\u304B\u3089\u4E00\u7DD2\u306B\u9811\u5F35\u3063\u3066\u884C\u3053\u3046\u306A\uFF01\uFF01\uFF01\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u8AB0\u3060\u30A2\u30F3\u30BF\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u79C1\u306F\u3053\u306E\u5854\u306E\u5B88\u8B77\u8005\u3001\u30D5\u30A7\u30B4\u30FC\u30EB\uFF01\n\u3064\u307E\u308A\u30E9\u30B9\u30DC\u30B9\u3060\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u305D\u306E\u30E9\u30B9\u30DC\u30B9\u304C\u3001\u306A\u3093\u3067\u5854\u306E\u5165\u53E3\u306B\u3044\u308B\u3093\u3060\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u2026\u3053\u306E\u5854\u306F\u3001\u5927\u6614\u306B\u795E\u69D8\u307F\u305F\u3044\u306A\u5B58\u5728\u304C\u5EFA\u3066\u305F\u3093\u3060\u3002\n\u5B88\u8B77\u8005\u3092\u5012\u305B\u308B\u304F\u3089\u3044\u5F37\u3044\u529B\u3092\u6301\u3063\u305F\u5B58\u5728\u306B\u3001\n\u81EA\u5206\u306E\u529B\u306E\u4E00\u90E8\u3092\u4E0E\u3048\u308B\u305F\u3081\u306B\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u79C1\u306F\u5B88\u8B77\u8005\u3068\u3057\u3066\u4F5C\u3089\u308C\u3001\u5854\u306E\u7BA1\u7406\u3092\u4EFB\u3055\u308C\u305F\u3002\n\u79C1\u3082\u5F35\u308A\u5207\u3063\u3066\u3055\u3001\u30C0\u30F3\u30B8\u30E7\u30F3\u904B\u55B6\u9811\u5F35\u3063\u305F\u3093\u3060\u3088\u3002\n\u8272\u3093\u306A\u30E2\u30F3\u30B9\u30BF\u30FC\u3068\u304B\u3001\u7F60\u3068\u304B\u4F5C\u3063\u3066\u3055\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305D\u3046\u3084\u3063\u3066\u5192\u967A\u8005\u3092\u5168\u529B\u3067\u8FFD\u3044\u6255\u3063\u305F\u3089\u2026\u2026\n\u3044\u3064\u306E\u9593\u306B\u304B\u3001\u8AB0\u3082\u6765\u306A\u304F\u306A\u3063\u3066\u3057\u307E\u3063\u305F\u3093\u3060\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3042\u307E\u308A\u306B\u3082\u5BC2\u3057\u3044\u304B\u3089\u3001\u6B21\u306B\u5192\u967A\u8005\u304C\u6765\u305F\u3089\u3001\n1\u968E\u304B\u3089\u4ED8\u304D\u3063\u5207\u308A\u3067\u30B5\u30DD\u30FC\u30C8\u3059\u308B\u3063\u3066\u6C7A\u3081\u305F\u3093\u3060\u3002\n\u305D\u3057\u3066100\u5E74\u3076\u308A\u306B\u5854\u306B\u6765\u305F\u306E\u304C\u304A\u524D\u3063\u3066\u8A33\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u9802\u4E0A\u306B\u884C\u304F\u306E\u304C\u7C21\u5358\u306B\u306A\u308B\u306E\u306F\u5B09\u3057\u3044\u304C\u3001\n\u3044\u3044\u306E\u304B\uFF1F\u3000\u305D\u3093\u306A\u3053\u3068\u3057\u3066"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u3041\u3001\u79C1\u3092\u4F5C\u3063\u305F\u5B58\u5728\u3082\u3082\u3046\u3069\u3063\u304B\u884C\u3063\u3061\u3083\u3063\u305F\u3057\u3001\n\u3076\u3063\u3061\u3083\u3051\u6570\u767E\u5E74\u3082\u7D4C\u904E\u3057\u3066\u3001\u9858\u3044\u306E\u30D1\u30EF\u30FC\u3082\u304B\u306A\u308A\u3057\u3087\u307C\u304F\u306A\u3063\u3066\u308B\u3057\u3001\n\u96E3\u6613\u5EA6\u304C\u4F4E\u304F\u306A\u3063\u3066\u3082\u59A5\u5F53\u304B\u306A\u3068\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u3041\u305D\u3093\u306A\u308F\u3051\u3067\u3001\u9802\u4E0A\u306B\u5230\u9054\u3059\u308B\u307E\u3067\u3088\u308D\u3057\u304F\u306A\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
  rewardItem: {fileID: 0}
