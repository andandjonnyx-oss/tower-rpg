  id: F62_S02
  zukanTitle: "\u304A\u7D04\u675F"
  floor: 62
  step: 2
  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3082\u3050\u3082\u3050\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: '-'
    text: "\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u30D0\u30CA\u30CA\u3092\u98DF\u3079\u308B\u3068\u3001\n\u305D\u306E\u76AE\u3092You\u306E\u76EE\u306E\u524D\u306B\u6295\u3052\u6368\u3066\u305F\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u2026\u2026\u4F55\u306E\u3064\u3082\u308A\u3060\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3044\u3084\u30FC\u3001\u305D\u308D\u305D\u308D\u7F60\u3068\u304B\u3082\u4F5C\u308D\u3046\u304B\u306A\u3068\u601D\u3063\u3066\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u3069\u771F\u3093\u4E2D\u306B\u30D0\u30CA\u30CA\u306E\u76AE\u3092\u7F6E\u3044\u3066\u8E0F\u3080\u8A33\u306A\u3044\u3060\u308D\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: '-'
    text: "You\u306F\u30D0\u30CA\u30CA\u306E\u76AE\u3092\u907F\u3051\u3066\u901A\u3063\u305F\u3002\n\u3059\u308B\u3068\u3001\u907F\u3051\u305F\u5148\u306E\u8DB3\u5143\u304B\u3089\u30AB\u30C1\u3063\u3068\u97F3\u304C\u3057\u3001\n\u982D\u4E0A\u304B\u3089\u91D1\u30C0\u30E9\u30A4\u304C\u843D\u3061\u3066\u6765\u3066You\u306B\u76F4\u6483\u3059\u308B\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u304E\u3083\u306F\u306F\u306F\u306F\u306F\u306F\u306F\uFF01\u3000\u3070\u30FC\u304B\u3070\u30FC\u304B\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: '-'
    text: "\u898B\u4E8B\u306B\u5F15\u3063\u304B\u304B\u3063\u3066\u60B6\u3048\u308BYou\u3092\u898B\u3066\u7206\u7B11\u3057\u306A\u304C\u3089\u3001\n\u9F3B\u6B4C\u6DF7\u3058\u308A\u3067\u305D\u306E\u5834\u3092\u53BB\u308D\u3046\u3068\u3059\u308B\u30D5\u30A7\u30B4\u30FC\u30EB\u3060\u304C\u3001\n\u524D\u65B9\u4E0D\u6CE8\u610F\u3067\u30D0\u30CA\u30CA\u306E\u76AE\u3092\u8E0F\u307F\u76DB\u5927\u306B\u3053\u3051\u3066\u3057\u307E\u3046\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u2026\u2026\u7F60\u306F\u5EC3\u6B62\u306B\u3057\u3088\u3046\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
