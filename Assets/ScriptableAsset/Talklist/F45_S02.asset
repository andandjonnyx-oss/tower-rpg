  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30A8\u30F3\u30D7\u30FC\u30B5\u306F\u30EC\u30D9\u30EB\u30C9\u30EC\u30A4\u30F3\u3057\u306A\u3044\u306E\u306B\u3001\n\u30AE\u30E3\u30B0\u307F\u305F\u3044\u306A\u540D\u524D\u306E\u30B9\u30E9\u30A4\u30E0\u304C\n\u30EC\u30D9\u30EB\u30C9\u30EC\u30A4\u30F3\u4F7F\u3063\u3066\u6765\u308B\u306E\u306F\u306A\u3041\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3068\u306F\u3044\u3048\u3001\u30EC\u30D9\u30EB\u30C9\u30EC\u30A4\u30F3\u306F\u60AA\u3044\u4E8B\u3060\u3051\u3058\u3083\u306A\u3044\u3002\n\u78BA\u304B\u306B\u30EC\u30D9\u30EB\u306F\u4E0B\u304C\u3063\u3066\u7D4C\u9A13\u5024\u3082\u6700\u521D\u304B\u3089\u3060\u304C\u3001\n\u30B9\u30C6\u30FC\u30BF\u30B9\u30DD\u30A4\u30F3\u30C8\u306F\u305D\u306E\u307E\u307E\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u7D4C\u9A13\u5024\u3068\u30B9\u30AD\u30EB\u30DD\u30A4\u30F3\u30C8\u306E\u52B9\u7387\u3001\n\u3063\u3066\u89B3\u70B9\u304B\u3089\u3059\u308C\u3070\u3001\u5E8F\u76E4\u306E\u65B9\u304C\u3044\u3044\u304B\u3089\u306A\u3002\n\u308F\u3056\u3068\u30EC\u30D9\u30EB\u30C9\u30EC\u30A4\u30F3\u3055\u308C\u307E\u304F\u308B\u306E\u3082\u3042\u308A\u304B\u3082\u306A\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u5909\u306A\u30B9\u30E9\u30A4\u30E0\u76F8\u624B\u306B\u3072\u305F\u3059\u3089\u9632\u5FA1\u3057\u3066\u3001\n\u30EC\u30D9\u30EB\u30C9\u30EC\u30A4\u30F3\u3055\u308C\u307E\u304F\u308B\u304A\u524D\u306A\u3093\u3066\n\u898B\u305F\u304F\u7121\u3044\u3051\u3069\u306A\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
