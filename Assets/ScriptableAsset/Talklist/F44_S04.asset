  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u30C1\u30E3\u30FC\u30E0\u3092\u5531\u3048\u305F\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3042\u308A\u3083\u3001\u5931\u6557\u304B\u3002\n\u307E\u3041\u300160\uFF05\u306F\u5916\u3059\u6642\u306F\u5916\u3059\u3088\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u30C1\u30E3\u30FC\u30E0\u3092\u5531\u3048\u305F\uFF01\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u30C1\u30E3\u30FC\u30E0\u3092\u5531\u3048\u305F\uFF01\n\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u30C1\u30E3\u30FC\u30E0\u3092\u5531\u3048\u305F\uFF01\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u30C1\u30E3\u30FC\u30E0\u3092\u5531\u3048\u305F\uFF01\n\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u30C1\u30E3\u30FC\u30E0\u3092\u5531\u3048\u305F\uFF01\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u30C1\u30E3\u30FC\u30E0\u3092\u5531\u3048\u305F\uFF01\n\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u30C1\u30E3\u30FC\u30E0\u3092\u5531\u3048\u305F\uFF01\u30D5\u30A7\u30B4\u30FC\u30EB\u306F\u30C1\u30E3\u30FC\u30E0\u3092\u5531\u3048\u305F\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u2026\u2026\u3075\u3063\u3001\u305D\u3046\u3044\u3046\u3053\u3068\u304B\u3002\n\u6700\u521D\u304B\u3089\u304A\u524D\u306F\u79C1\u306B\u9B45\u4E86\u3055\u308C\u3066\u305F\u3063\u3066\u3053\u3068\u3060\u306A\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u8336\u756A\u3082\u7A0B\u3005\u306B\u3001\u3053\u3053\u304B\u3089\u306F\u9B45\u4E86\u304C\u8FFD\u52A0\u3055\u308C\u308B\u3002\n\u4ED6\u306E\u72B6\u614B\u7570\u5E38\u306E\u8010\u6027\u304C-100\u3055\u308C\u308B\u306E\u3068\u3001\n\u304A\u524D\u306B\u306F\u3068\u3042\u308B\u96A0\u3057\u52B9\u679C\u304C\u3042\u308B\u3093\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305D\u3057\u3066\u6050\u308D\u3057\u3044\u3053\u3068\u306B\u3001\u6CBB\u7642\u30A2\u30A4\u30C6\u30E0\u3082\u9B54\u6CD5\u3082\u7121\u3044\u3002\n\u8208\u596E\u3057\u305F\u3089\u4E00\u65E6\u5E30\u3063\u3066\u5BDD\u3066\u843D\u3061\u7740\u304F\u3057\u304B\u306A\u3044\u3063\u3066\u3053\u3068\u3060\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3067\u3082\u5927\u4E08\u592B\uFF01\u3000\u3053\u306E\u30A2\u30A4\u30C6\u30E0\u3055\u3048\u3042\u308C\u3070\u3001\n\u9B45\u4E86\u306B\u5B8C\u5168\u8010\u6027\u304C\u6301\u3066\u307E\u3059\uFF01\n\u3053\u308A\u3083\u3042\u5E38\u5099\u3059\u308B\u3057\u304B\u7121\u3044\u306A\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
