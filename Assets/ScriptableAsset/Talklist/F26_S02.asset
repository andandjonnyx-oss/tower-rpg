  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3053\u304B\u3089\u306F\u5F37\u6575\u30BE\u30FC\u30F3\u3060\uFF01\n\u3061\u3083\u3093\u3068\u8A71\u3092\u805E\u304B\u306A\u3044\u3068\u8A70\u3080\u305E\uFF1F"
