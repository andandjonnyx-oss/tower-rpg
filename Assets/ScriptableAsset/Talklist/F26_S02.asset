    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u305A\u306F\u30C8\u30ED\u30FC\u30EB\u3060\uFF01\n\u898B\u305F\u76EE\u306F\u5317\u6B27\u306E\u5996\u7CBE\u30E2\u30C1\u30FC\u30D5\u3060\u304C\u3001\n\u4E2D\u8EAB\u306F\u3088\u304F\u3042\u308B\u81EA\u52D5\u56DE\u5FA9\u6301\u3061\u306E\u8133\u7B4B\u3060\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B21\u306B\u30AF\u30A4\u30C3\u30AF\u30B7\u30EB\u30D0\u30FC\u3060\uFF01\n\u5168\u3066\u306E\u884C\u52D5\u304C\u5148\u5236\u653B\u6483\u306A\u4E0A\u306B\n\u3068\u306B\u304B\u304F\u56DE\u907F\u304C\u9AD8\u3044\uFF01\nDEX\u304C\u4F4E\u3044\u3068\u9B3C\u9580\u3060\u305C\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6700\u5F8C\u306B5\u30BF\u30FC\u30F3\u76EE\u306B\u81EA\u7206\u304F\u3093\u3060\uFF01\n5\u30BF\u30FC\u30F3\u76EE\u306E\u6B8B\u308AHP\u304C\u305D\u306E\u307E\u307E\u5A01\u529B\u306B\u306A\u308B\u305E\uFF01\n\u6700\u5F8C\u306E\u30BF\u30FC\u30F3\u306B\u653B\u6483\u3059\u308B\u304B\u9632\u5FA1\u3059\u308B\u304B\u60A9\u3080\u306A\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
