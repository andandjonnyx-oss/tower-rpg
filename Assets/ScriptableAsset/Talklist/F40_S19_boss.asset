  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305F\u3001\u5927\u5909\u3060\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u4F55\u304C\u3042\u3063\u305F\u3093\u3060\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3044\u3084\u3055\u3001\u304A\u524D\u304C\u3053\u3053\u306B\u6765\u308B\u524D\u306B\u3001\u5BC2\u3057\u3044\u304B\u3089\u5916\u306E\u4E16\u754C\u306B\u3044\u308B\n\u732B\u3063\u3066\u751F\u304D\u7269\u3092\u9B54\u529B\u3067\u4F5C\u3063\u3066\u30DA\u30C3\u30C8\u306B\u3057\u3066\u53EF\u611B\u304C\u3063\u3066\u305F\u3093\u3060\u3088\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3067\u3082\u304A\u524D\u304C\u3053\u3053\u306B\u6765\u305F\u304B\u3089\u304A\u524D\u306B\u4ED8\u304D\u3063\u5207\u308A\u3067\u3055\u3001\n\u305D\u306E\u7D50\u679C\u9003\u3052\u3061\u307E\u3063\u3066\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u898B\u3064\u3051\u305F\u3068\u601D\u3063\u305F\u3089\u3001\u5B8C\u5168\u306B\u91CE\u751F\u5316\u3057\u3066\u3066\u3001\n\u3057\u304B\u3082\u3053\u306E\u5148\u306E\u30DC\u30B9\u3092\u5012\u3057\u3066\u81EA\u5206\u304C\u30DC\u30B9\u306B\u306A\u3063\u3061\u307E\u3063\u305F\u3002\n\u53EF\u611B\u304C\u308A\u904E\u304E\u3066\u7121\u99C4\u306B\u529B\u3092\u4E0E\u3048\u305F\u304B\u3089\u5834\u9055\u3044\u306B\u5F37\u3044\u305C\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u304A\u524D\u304C\u9B54\u529B\u3067\u4F5C\u3063\u305F\u3093\u3060\u304B\u3089\u3001\u6D88\u305B\u3070\u3044\u3044\u3060\u308D\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305D\u3093\u306A\u4E8B\u51FA\u6765\u308B\u8A33\u7121\u3044\u3060\u308D\uFF01\n\u3044\u3044\u304B\u3001\u7D76\u5BFE\u306B\u30A8\u30DF\u30EA\u30FC\u3061\u3083\u3093\u3092\u50B7\u3064\u3051\u308B\u306A\u3088\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u3069\u3046\u3057\u308D\u3063\u3066\u8A00\u3046\u3093\u3060\u3088\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
