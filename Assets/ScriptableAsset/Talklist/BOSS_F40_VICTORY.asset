    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u304A\u524D\u306B\u3082\u5148\u4EE3\u30A8\u30DF\u30EA\u30FC\u3061\u3083\u3093\u3092\u3084\u308B\u304B\u3089\u3001\n\u53CD\u7701\u3057\u3066\u3061\u3083\u3093\u3068\u98FC\u3046\u3093\u3060\u305E\u3002\n\u5165\u624B\u3092\u8AE6\u3081\u3089\u308C\u306A\u3044\u3057\u6368\u3066\u3089\u308C\u306A\u3044\u546A\u3044\u306E\u30A2\u30A4\u30C6\u30E0\u306B\u3057\u3066\u304A\u3044\u305F\u304B\u3089\u306A\u3002"
