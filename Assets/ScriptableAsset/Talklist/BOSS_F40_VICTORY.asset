  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30A8\u30DF\u30EA\u30FC\u3061\u3083\u3042\u3042\u3042\u3042\u3042\u3042\u3042\u3042\u3042\u3042\u3093\uFF01\n\u3046\u308F\u3042\u3042\u3042\u3042\u3042\u3042\u3042\u3042\u3042\u3042\u3042\u3042\u3042\uFF01"
