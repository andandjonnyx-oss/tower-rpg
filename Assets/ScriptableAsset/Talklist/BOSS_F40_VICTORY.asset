  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u52D5\u7269\u8650\u5F85\u306F\u3093\u305F\u30FC\u3044\uFF01\n\u30A4\u30D9\u30F3\u30C8\u6226\u306B\u52DD\u3064\u305F\u3081\u306B\u7A3C\u304E\u307E\u304F\u3063\u3066\u307E\u3067\u3001\n\u3053\u3093\u306A\u3053\u3068\u304C\u3084\u308A\u305F\u304B\u3063\u305F\u306E\u304B\u304A\u524D\u306F\uFF01"
