  zukanTitle: "\u6700\u8FD1\u306E\u5E83\u544A\u9577\u3059\u304E\u3060\u3088\u306A"
  floor: 55
  step: 2
  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6700\u8FD1\u306F\u5E73\u6C17\u30671\u3064\u306E\u5E83\u544A\u30673\u3064\u306E\u30A2\u30D7\u30EA\u3092\u6D41\u3057\u305F\u308A\u3059\u308B\u3088\u306A\u2026\u2026\n\u81EA\u52D5\u3067\u5207\u308A\u66FF\u308F\u3089\u305A\u306B\u3001\u3044\u3061\u3044\u3061\xD7\u30DC\u30BF\u30F3\u3068\u304B\u62BC\u3059\u5FC5\u8981\u304C\u3042\u3063\u305F\u308A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u5E83\u544A\u30D3\u30B8\u30CD\u30B9\u30E2\u30C7\u30EB\u306F\u9650\u754C\u304C\u6765\u3066\u308B\u304B\u3089\u3001\n\u305D\u306E\u5206\u3069\u3053\u3082\u6570\u3092\u5897\u3084\u3059\u3057\u304B\u7121\u3044\u3093\u3060\u308D\u3046\u306A\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305B\u3081\u3066\u7686\u306B\u306F\u5E83\u544A\u3067\u5ACC\u306A\u60F3\u3044\u3057\u3066\u6B32\u3057\u304F\u7121\u3044\u304B\u3089\u3001\n\u3053\u306E\u30B2\u30FC\u30E0\u306E\u5E83\u544A\u306F\u5B8C\u6210\u3059\u308C\u3070\u30B9\u30AD\u30C3\u30D7\u53EF\u80FD\u306A\u3001\n\u30B8\u30B0\u30BD\u30FC\u30D1\u30BA\u30EB\u5F62\u5F0F\u306B\u3059\u308B\u3064\u3082\u308A\u3060\u305C\u3002\u795E\u30B2\u30FC\u3060\u308D\u3046\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
  rewardItem: {fileID: 0}
