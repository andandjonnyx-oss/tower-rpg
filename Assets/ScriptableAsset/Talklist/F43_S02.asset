  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u56F3\u9451\u306F\u6709\u52B9\u6D3B\u7528\u3057\u3066\u308B\u304B\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u7279\u306B\u30E2\u30F3\u30B9\u30BF\u30FC\u306F\u3001\u4E00\u822C\u3060\u308D\u3046\u3068\u30DC\u30B9\u3060\u308D\u3046\u3068\u3001\n\u300E\u6226\u3063\u305F\u77AC\u9593\u300F\u306B\u767B\u9332\u3055\u308C\u308B\u304B\u3089\u306A\u3002\n\u521D\u898B\u3067\u8A70\u3093\u3060\u6575\u3067\u3082\u56F3\u9451\u3092\u898B\u308C\u3070\u5BFE\u7B56\u304C\u7DF4\u308C\u308B\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u672A\u767A\u898B\u306E\u30A2\u30A4\u30C6\u30E0\u306A\u3093\u304B\u3082\u3001\n\u3069\u3053\u306B\u843D\u3061\u3066\u308B\u304B\u306E\u30D2\u30F3\u30C8\u304C\u8CB0\u3048\u308B\u304B\u3089\u3001\n\u65B0\u3057\u3044\u6B66\u5668\u3084\u9B54\u6CD5\u3092\u96C6\u3081\u308B\u306E\u3082\u30A2\u30EA\u3060\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3046\u3044\u3046\u4F1A\u8A71\u3060\u3063\u3066\u3001\u3044\u3064\u3067\u3082\u898B\u8FD4\u305B\u308B\u305C\uFF01\n\u77E5\u8B58\u306F\u30D1\u30EF\u30FC\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
