    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u2026\u2026\u4F55\u304C\u3057\u305F\u3044\u3093\u3060\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30DB\u30EF\u30A4\u30C8\u30C7\u30FC\u306E\u304A\u8FD4\u3057\u3092\u5BC4\u8D8A\u305B\u3063\u3064\u3063\u3066\u3093\u3060\u3088\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "314\u3068\u8A00\u3048\u3070\u30DB\u30EF\u30A4\u30C8\u30C7\u30FC\uFF01\n3\u500D\u8FD4\u3057\u304C\u5E38\u8B58\u3060\u308D\u3046\u304C\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u7121\u8336\u3092\u8A00\u3046\u306A\u3088\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3066\u3044\u3046\u304B\u3061\u3083\u3093\u3068\u98DF\u3063\u305F\u3088\u306A\uFF1F\n\u3053\u306E\u6642\u70B9\u3067\u306F\u7834\u683C\u306EMP\u56DE\u5FA9\u3060\u304B\u3089\u3063\u3066\n\u5009\u5EAB\u306B\u9810\u3051\u3063\u3071\u306A\u3057\u306B\u3057\u305F\u6319\u53E5\u6700\u5F8C\u307E\u3067\u5FD8\u308C\u308B\u3068\u304B\u306A\u3044\u3088\u306A\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u306F\u3041\u2026\u2026\u304A\u8FD4\u3057\u306F\u3044\u3044\u3084\u3002\n\u4EE3\u308F\u308A\u306B\u30EC\u30D3\u30E5\u30FC\u3057\u3066\u304F\u308C\u3088\u3002\u26063.14\u3092\u76EE\u6307\u3057\u3066\u308B\u3093\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
