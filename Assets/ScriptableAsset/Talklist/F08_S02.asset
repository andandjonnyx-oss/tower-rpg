  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u554F\u984C\uFF01\u3000\u305F\u304B\u3057\u541B\u306F\u3001\u6BD2\u8010\u6027\u309250\u5897\u3084\u3059\u6BD2\u306E\u8B77\u7B26\u3092\u6301\u3061\u3001\n\u6BD2\u8010\u6027\u309250\u5897\u3084\u3059\u30DD\u30A4\u30BA\u30F3\u30CA\u30A4\u30D5\u3092\u88C5\u5099\u3057\u3066\u3044\u307E\u3059\u3002\n\u305F\u304B\u3057\u541B\u306E\u6BD2\u8010\u6027\u306F\u3044\u304F\u3064\u306B\u306A\u3063\u305F\u3067\u3057\u3087\u3046\u304B\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "50+5\u306755\u3060\u308D\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3076\u3076\u30FC\u3063\uFF01\u3000\u88C5\u5099\u306F1\u3064\u3060\u3051\u306A\u306E\u3067\u3001\u8A08\u7B97\u304C\u5225\u3067100\uFF05\u53CD\u6620\uFF01\n\u3068\u3044\u3046\u3053\u3068\u3067\u6B63\u89E3\u306F50+50\u3067100\u3067\u3057\u305F\uFF01\n\u5916\u308C\u305F\u3051\u3069\u5B09\u3057\u3044\u304B\u3089\u3044\u3044\u3060\u308D\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u5F53\u305F\u308A\u524D\u3060\u3051\u3069\u88C5\u5099\u4E2D\u306E\u6B66\u5668\u306E\u52B9\u679C\u306E\u307F\u9069\u7528\u3060\u304B\u3089\u306A\uFF1F\n\u6226\u95D8\u4E2D\u306B\u88C5\u5099\u5909\u66F4\u3068\u304B\u3057\u305F\u3089\u305D\u306E\u6642\u70B9\u3067\u8010\u6027\u306F\u5909\u308F\u308B\u304B\u3089\u306A\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
