  id: F35_S02
  zukanTitle: "\u77F3\u5316\u306E\u6050\u6016"
  floor: 35
  step: 2
  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u306F\u30FC\u3001\u3084\u3063\u3068\u77F3\u5316\u304C\u89E3\u3051\u305F\u3002\n\u65B0\u3057\u304F\u72B6\u614B\u7570\u5E38\u3092\u4F5C\u3063\u3066\u898B\u305F\u3093\u3060\u304C\u3001\n\u65B0\u3057\u3044\u304B\u3089\u8010\u6027\u304C\u7121\u304F\u3066\u3053\u306E\u69D8\u3088\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6D41\u77F3\u306B\u30E9\u30B9\u30DC\u30B9\u306B\u77F3\u5316\u304C\u901A\u308B\u306A\u3093\u3066\u3001\n\u3042\u3063\u3061\u3083\u306A\u3089\u306A\u3044\u3053\u3068\u3060\u304B\u3089\u3001\u304A\u524D\u3068\u6226\u3046\u307E\u3067\u306B\u306F\n\u5B8C\u5168\u8010\u6027\u3064\u3051\u3068\u304F\u304B\u3089\u5B89\u5FC3\u3057\u308D\u3088\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3068\u3044\u3046\u308F\u3051\u3067\u77F3\u5316\u306E\u767B\u5834\u3060\u3002\n\u4ECA\u307E\u3067\u306E\u72B6\u614B\u7570\u5E38\u3068\u9055\u3063\u3066\u81EA\u7136\u6CBB\u7652\u3057\u306A\u3044\u3057\u3001\n\u6226\u95D8\u4E2D\u3067\u3082\u5854\u3067\u3082\u77F3\u5316\u304C\u9032\u884C\u3057\u3066\u3057\u307E\u3046\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u77F3\u5316\u9032\u884C\u4E2D\u306B\u66F4\u306B\u77F3\u5316\u3092\u53D7\u3051\u305F\u3089\u30BF\u30FC\u30F3\u77ED\u7E2E\u3002\n\u30D7\u30EC\u30A4\u30E4\u30FC\u5074\u306F\u7336\u4E88\u30BF\u30FC\u30F3\u304C\u5C11\u306A\u3044\u304B\u3089\u3001\n\u53D7\u3051\u305F\u3089\u3059\u3050\u56DE\u5FA9\u3059\u308B\u304B\u6226\u95D8\u7D42\u308F\u3089\u305B\u305F\u65B9\u304C\u3044\u3044\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6226\u95D8\u4E2D\u306B\u77F3\u5316\u5B8C\u4E86\u3057\u305F\u3089\u6557\u5317\u3060\u304C\u3001\n\u5854\u306E\u4E2D\u3067\u77F3\u5316\u5B8C\u4E86\u3057\u305F\u308930\u79D2\u64CD\u4F5C\u4E0D\u80FD\u3067\u6E08\u3080\u3002\n\u6CBB\u7642\u624B\u6BB5\u304C\u7121\u3044\u6642\u306F\u3001\u5854\u3067\u5B8C\u4E86\u3059\u308B\u306E\u3092\u7948\u308B\u3057\u304B\u7121\u3044\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305F\u3060\u5B8C\u5168\u306B\u30C7\u30E1\u30EA\u30C3\u30C8\u3060\u3051\u3058\u3083\u7121\u304F\u3066\u3001\n\u77F3\u5316\u304C\u9032\u3080\u306B\u3064\u308C\u3066\u9632\u5FA1\u529B\u304C\u30A2\u30C3\u30D7\u3059\u308B\u3002\n\u8EAB\u4F53\u304C\u77F3\u306B\u8FD1\u3065\u304F\u8A33\u3060\u304B\u3089\u306A\u3002\n\u77F3\u5316\u4E2D\u306F\u3068\u306B\u304B\u304F\u5B88\u308A\u3092\u6C17\u306B\u305B\u305A\u6575\u3092\u5012\u305B\u3063\u3066\u3053\u3068\u3060\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
  rewardItem: {fileID: 11400000, guid: 7b946f0c1d996c1428a7591b77480200, type: 2}
