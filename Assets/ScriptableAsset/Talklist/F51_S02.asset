  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u306A\u3093\u3060\u304B\u5B9A\u671F\u7684\u306B\n\u3053\u3053\u304B\u3089\u306F\u4E00\u5C64\u53B3\u3057\u304F\u306A\u308B\u305E\u3001\u307F\u305F\u3044\u306A\u4E8B\u8A00\u3063\u3066\u3093\u306A\u2026\u2026\nRPG\u3063\u3066\u305D\u3046\u3044\u3046\u3082\u3093\u3060\u304B\u3089\u4ED5\u65B9\u306A\u3044\u3051\u3069\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3042\u3068\u3001\u6B63\u76F4\u79C1\u304C\u5F37\u3059\u304E\u305F\u305B\u3044\u3067\u3001\n\u3053\u3053\u306B\u6765\u308B\u6BB5\u968E\u3067\u306F\u304B\u306A\u308A\u5F37\u304F\u306A\u3063\u3066\u308B\u53EF\u80FD\u6027\u3082\u3042\u308B\u3088\u306A\u2026\u2026\n\u30EC\u30D9\u30EB80\u304F\u3089\u3044\u3042\u308B\u4EBA\u3082\u3044\u308B\u3093\u3058\u3083\u306A\u3044\u304B\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3068\u306F\u3044\u3048\u300150\u968E\u307E\u3067\u306B\u72B6\u614B\u7570\u5E38\u3060\u3063\u305F\u308A\u3001\n\u6575\u306E\u7279\u6B8A\u884C\u52D5\u3060\u3063\u305F\u308A\u306F\u307B\u3068\u3093\u3069\u51FA\u63C3\u3063\u3066\u3044\u308B\u3002\n\u305D\u308C\u3092\u4F7F\u3046\u6575\u3082\u30C1\u30E5\u30FC\u30C8\u30EA\u30A2\u30EB\u7684\u306A\u5B58\u5728\u3060\u304C\u3001"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4ECA\u5F8C\u306F\u8272\u3005\u8907\u5408\u3057\u305F\u8981\u7D20\u3092\u6301\u3064\u6575\u3092\n\u3058\u3083\u3093\u3058\u3083\u3093\u51FA\u3059\u4E88\u5B9A\u3060\u304B\u3089\u306A\u3002\u899A\u609F\u3057\u3068\u3051\u3088\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
