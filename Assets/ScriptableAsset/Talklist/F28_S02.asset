  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u81EA\u7206\u3055\u308C\u3066\u308B\u304B\uFF1F\n\u30D2\u30F3\u30C8\u3068\u3057\u3066\u306F\u3001\u6C17\u7D76\u306B\u5B8C\u5168\u8010\u6027\u306F\u7121\u3044\u304B\u3089\u3001\n\u30AB\u30A6\u30F3\u30C8\u30C0\u30A6\u30F3\u9014\u4E2D\u306B\u6C17\u7D76\u3055\u305B\u308C\u3070\u3084\u308A\u76F4\u3057\u306B\u306A\u308B\u305C\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u5F8C\u306F\u9632\u5FA1\u529B\u3068\u304B\u306F\u4E00\u5207\u7121\u3044\u304B\u3089\u3001\n\u30C0\u30E1\u30FC\u30B8\u8A08\u7B97\u304C\u3057\u3084\u3059\u3044\u306A\u3002\nCT3\u306E\u30B9\u30AD\u30EB\u306A\u30892\u56DE\u4F7F\u3048\u308B\u3057\u306A\u3002\n\u307E\u3041\u3001\u3053\u306E\u8FBA\u306BCT3\u306E\u706B\u529B\u6280\u6301\u3063\u305F\u88C5\u5099\u306F\u7121\u3044\u3093\u3060\u304C\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u5927\u62B5\u306E\u653B\u6483\u306F\u547D\u4E2D\u738795\uFF05\u3060\u304B\u3089\u3001\n1\u56DE\u5916\u3057\u3061\u3083\u3063\u3066\u30C0\u30E1\u30FC\u30B8\u8A08\u7B97\u304C\u5D29\u308C\u3066\u5927\u60E8\u4E8B\uFF01\n\u3063\u3066\u306E\u3082\u73FE\u5B9F\u7684\u306B\u8D77\u304D\u3061\u3083\u3046\u3093\u3060\u3088\u306A\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
