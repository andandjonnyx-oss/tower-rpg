  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u524D\u306B\u3082\u8AAC\u660E\u3057\u305F\u901A\u308A\u3001\u547D\u4E2D\u7387\u306F25\uFF05\u306E\u4FDD\u8A3C\u304C\u3042\u308B\u3057\u3001\n\u30C0\u30E1\u30FC\u30B8\u30821\u306E\u4FDD\u8A3C\u304C\u3042\u308B\u3002\n\u3064\u3044\u3067\u306B\u30AF\u30EA\u30C6\u30A3\u30AB\u30EB\u304C\u51FA\u308C\u3070\u9632\u5FA1\u5B8C\u5168\u7121\u8996\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3060\u304B\u3089\u3001\u706B\u529B\u306F\u4F4E\u3044\u3051\u3069\u4F55\u9023\u767A\u3082\u653E\u3066\u308B\u3088\u3046\u306A\u3001\n\u30B9\u30AD\u30EB\u3092\u6301\u3063\u305F\u6B66\u5668\u304C\u3042\u308C\u3070\u697D\u52DD\u3060\u3063\u305F\u308A\u3059\u308B\u3093\u3060\u3088\u306A\u3041\u2026\u2026\n\u3042\u3001\u30A2\u30A4\u30B9\u98DF\u3046\u304B\uFF1F"
