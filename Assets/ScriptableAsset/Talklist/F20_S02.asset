  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3053\u306E\u30EC\u30A2\u6575\u306F\u30E1\u30BF\u2026\u2026\u30B7\u30EB\u30D0\u30FC\u30B9\u30E9\u30A4\u30E0\u3060\uFF01\n\u786C\u3044\uFF01\u907F\u3051\u308B\uFF01\u7D4C\u9A13\u5024\u305F\u304F\u3055\u3093\uFF01"
