  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6575\u306E\u904B\u306E\u534A\u5206\u4EE5\u4E0A\u3042\u308C\u3070\u3001\u5C11\u306A\u304F\u3068\u3082\u4E0D\u5229\u306B\u306F\u306A\u3089\u306A\u3044\u305C\u3002\n\u9006\u306B\u6709\u5229\u306B\u306A\u308B\u306B\u306F\u6575\u306E\u904B\u306E1.5\u500D\u304C\u5FC5\u8981\u306B\u306A\u308B\u3002"
