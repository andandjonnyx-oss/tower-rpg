  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u7121\u632F\u308A\u3067\u4ED6\u306E\u30B9\u30C6\u30FC\u30BF\u30B9\u3092\u4E0A\u3052\u3066\u6575\u306E\u5F37\u529B\u306A\u884C\u52D5\u3068\u6E21\u308A\u5408\u3046\u304B\u3001\n\u7A0B\u3005\u306B\u3042\u3052\u3066\u666E\u901A\u306E\u30D0\u30E9\u30F3\u30B9\u3067\u6311\u3080\u304B\u3001\n\u904B\u3092\u4E0A\u3052\u307E\u304F\u3063\u3066\u5236\u9650\u3055\u308C\u305F\u6575\u3068\u6E21\u308A\u5408\u3046\u304B\u3001\u3063\u3066\u3068\u3053\u3060\u306A\u3002"
