  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3042\u306E\u76FE\u306B\u306F\u82E6\u6226\u3057\u3066\u308B\u304B\uFF1F\n\u307E\u3041\u3001\u653B\u6483\u529B\u304C\u305D\u308C\u306A\u308A\u306B\u3042\u3063\u305F\u3089\u96D1\u9B5A\u306A\u3093\u3060\u304C\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u305F\u307E\u306B\u3042\u3044\u3064\u306F\u30D2\u30FC\u30EB\u3092\u4F7F\u3046\u3093\u3060\u3051\u3069\u306A\u3001\n\u304A\u524D\u306E\u904B\u304C\u9AD8\u304B\u3063\u305F\u3089\u4F7F\u308F\u306A\u3044\u3093\u3060\u305C\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3056\u3063\u304F\u308A\u8A00\u3048\u3070\u3001\u6575\u306E\u884C\u52D5\u306F1\u304B\u3089100\u306E\u30B5\u30A4\u30B3\u30ED\u3092\u632F\u3063\u3066\u3001\n\u3042\u306E\u76FE\u306A\u308980\uFF5E100\u3067\u30D2\u30FC\u30EB\u3092\u4F7F\u3046\u3093\u3060\u304C\u3001\n\u30B5\u30A4\u30B3\u30ED\u306E\u9762\u6570\u306F\u904B\u306E\u5DEE\u3067\u5909\u308F\u308B\u3093\u3060\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3063\u3061\u306E\u904B\u304C\u5341\u5206\u306B\u9AD8\u3051\u308C\u3070\u3001\u76F8\u624B\u306E\u30B5\u30A4\u30B3\u30ED\u306F80\u307E\u3067\u306B\u306A\u308B\u3002\n\u3060\u304B\u3089\u30D2\u30FC\u30EB\u3092\u4F7F\u308F\u306A\u304F\u306A\u308B\u3002\u9006\u306B\u3053\u3063\u3061\u306E\u904B\u304C\u4F4E\u3059\u304E\u305F\u3089\u3001\n\u76F8\u624B\u306E\u30B5\u30A4\u30B3\u30ED\u306F120\u306B\u306A\u3063\u3066\u3001\u30D2\u30FC\u30EB\u3092\u4F7F\u3044\u3084\u3059\u304F\u306A\u308B\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3063\u3061\u306E\u904B\u304C\u4F4E\u3044\u6642\u3060\u3051\u4F7F\u3046\u5371\u967A\u6280\u3001\u307F\u305F\u3044\u306A\u306E\u3082\u3042\u308B\u304B\u3089\u3001\n\u7121\u632F\u308A\u306F\u305D\u308D\u305D\u308D\u3084\u3081\u3068\u3044\u305F\u65B9\u304C\u3044\u3044\u305C\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
