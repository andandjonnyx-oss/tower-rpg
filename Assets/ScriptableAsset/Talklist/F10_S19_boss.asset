  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30DC\u30B9\u306F\u6BD2\u3068\u708E\u306E\u4F7F\u3044\u624B\u3060\uFF01\n\u6BD2\u306F\u7269\u7406\u3060\u3051\u3069\u708E\u306F\u9B54\u6CD5\u3060\u304B\u3089\u5384\u4ECB\u3060\u306A\uFF01\n\u708E\u8010\u6027\u304C\u7121\u304B\u3063\u305F\u3089\u53B3\u3057\u3044\u305E\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4F53\u529B\u3082\u304B\u306A\u308A\u9AD8\u3044\u3051\u3069\u3001\u610F\u5916\u306A\u5F31\u70B9\u304C\u3042\u308B\u305E\uFF01\n\u2026\u2026\u3093\uFF1F\u3000\u306A\u3093\u3060\u3053\u308C\u3001\u304A\u524D\u306E\u843D\u3068\u3057\u7269\u304B\uFF1F\n\u307B\u3089\u3001\u3061\u3083\u3093\u3068\u6301\u3063\u3068\u3051\u3088\uFF01"
