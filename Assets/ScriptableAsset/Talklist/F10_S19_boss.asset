  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3044\u3088\u3044\u3088\u3053\u306E\u5148\u30DC\u30B9\u3060\uFF01\n\u3053\u3053\u307E\u3067\u6765\u3066\u8CA0\u3051\u305F\u304F\u306F\u7121\u3044\u3088\u306A\uFF1F\n\u306A\u3089\u8A71\u3092\u3061\u3083\u3093\u3068\u805E\u304F\u3093\u3060\u305E\uFF01"
