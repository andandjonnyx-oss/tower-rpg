  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "1\u968E\u5236\u8987\u304A\u3081\u3067\u3068\u3046\uFF01\n\u3053\u308C\u3092100\u56DE\u7E70\u308A\u8FD4\u3059\u3060\u3051\u3060\uFF01\u3000\u7C21\u5358\u3060\u306A\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u2026\u2026\u5854\u306B\u5165\u3063\u3066\u304B\u3089\u305A\u3063\u3068\u4E00\u672C\u9053\u306A\u3093\u3060\u304C\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3042\u3001\u6C17\u4ED8\u3044\u3061\u3083\u3063\u305F\uFF1F\n\u3044\u3084\u30FC\u3001\u6614\u306F\u9B54\u6CD5\u306E\u529B\u3067\u5B9F\u969B\u306E\u5927\u304D\u3055\u3088\u308A\u5E83\u304F\u4F5C\u3063\u3066\u3001\n\u8FF7\u5BAE\u3063\u307D\u304F\u3057\u3066\u30011\u968E\u9032\u3080\u306E\u306B\u3082\u7D50\u69CB\u8FF7\u3046\u3088\u3046\u306B\u3057\u305F\u3093\u3060\u3051\u3069\u3055\u30FC\u3001"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u308C\u304C\u307E\u3041\u5927\u4E0D\u8A55\uFF01\n\u3068\u3044\u3046\u308F\u3051\u3067\u3001\u9B54\u6CD5\u306E\u529B\u3067\u4E00\u672C\u9053\u306B\u3057\u3066\u8FF7\u308F\u306A\u3044\u3088\u3046\u306B\u3057\u305F\u305C\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u305D\u308C\u3068\u3001\u5F8C\u308D\u306B\u623B\u308C\u306A\u3044\u3093\u3060\u304C\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u8150\u3063\u3066\u3082\u8A66\u7DF4\u306E\u5854\u3060\u304B\u3089\u306A\uFF01\n\u7A3C\u304E\u5834\u3092\u898B\u3064\u3051\u3066\u3046\u308D\u3046\u308D\u3059\u308B\u3068\u304B\u306F\u5192\u967A\u8005\u30B7\u30C3\u30D7\u306B\u53CD\u3059\u308B\uFF01\n\u7537\u306A\u3089\u524D\u3078\u9032\u3081\uFF01\u3000\u7279\u5B9A\u306E\u968E\u3067\u7A3C\u304E\u305F\u304D\u3083\u4F55\u5EA6\u3082\u6F5C\u308C\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3042\u3001\u3061\u306A\u307F\u306B\u4E2D\u9593\u5730\u70B9\u306F11\u968E\u3060\u304B\u3089\u306A\u3002\n\u305D\u308C\u307E\u3067\u306F\u9014\u4E2D\u3067\u3084\u3089\u308C\u305F\u30891\u968E\u304B\u3089\u3084\u308A\u76F4\u3057\u3060\u305C\u3002\n\u81EA\u7136\u3068\u7A3C\u3052\u3066\u3044\u3044\u3088\u306A\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u89AA\u5207\u306A\u3093\u3060\u304B\u4E0D\u89AA\u5207\u306A\u3093\u3060\u304B\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
  rewardItem: {fileID: 0}
