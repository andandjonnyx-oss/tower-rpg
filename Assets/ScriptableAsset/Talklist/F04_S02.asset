  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3053\u304B\u3089\u306F\u3061\u3087\u3063\u3068\u3060\u3051\u5F37\u3044\u6575\u304C\u51FA\u3066\u6765\u308B\u305E\uFF01\n\u4E8B\u524D\u306B\u4E88\u7FD2\u3057\u3088\u3046\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u305A\u306F\u30BE\u30F3\u30D3\u3060\uFF01\u3000HP\u304C\u304B\u306A\u308A\u9AD8\u3044\u3057\u653B\u6483\u529B\u3082\u3042\u308B\u3051\u3069\u3001\n\u30DC\u30FC\u3063\u3068\u3057\u3066\u308B\u3053\u3068\u304C\u591A\u3044\u305E\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B21\u306F\u30DF\u30C4\u30D0\u30C1\u3060\uFF01\u3000\u56DE\u907F\u304C\u9AD8\u3044\u305E\uFF01\n\u5148\u5236\u3067\u81EA\u7206\u3057\u3066\u6BD2\u3082\u3064\u3051\u3066\u304F\u308B\u5ACC\u306A\u6575\u3060\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6700\u5F8C\u306B\u30AA\u30FC\u30AF\u3060\uFF01\u3000\u547D\u4E2D\u306F\u4F4E\u3044\u3051\u3069\u3001\n\u706B\u529B\u306E\u9AD8\u3044\u4E00\u6483\u3092\u4F7F\u3063\u3066\u6765\u308B\u305E\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u8CA0\u3051\u3066\u3082\u4E00\u56DE\u6226\u3063\u305F\u3089\u56F3\u9451\u306B\u767B\u9332\u3055\u308C\u3066\u3001\n\u305D\u3053\u3067\u8272\u3005\u60C5\u5831\u304C\u898B\u308C\u308B\u304B\u3089\u306A\uFF01\n\u62E0\u70B9\u3067\u3058\u3063\u304F\u308A\u5BFE\u7B56\u3092\u7DF4\u308C\u3088\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
