  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30C0\u30E1\u30FC\u30B8\u8A08\u7B97\u3092\u3059\u308B\u6642\u306F\u3001\n\u307E\u305A\u8010\u6027\u306B\u3088\u308B\u5897\u6E1B\u304C\u5165\u308B\u305C\u3002"
