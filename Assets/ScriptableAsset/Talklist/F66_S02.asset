  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u4ECA\u66F4\u3060\u3051\u3069\u300161\u968E\uFF5E70\u968E\u306E\u4E8B\u3092\n70\u5C64\u3063\u3066\u547C\u3076\u306E\u306F\u9055\u548C\u611F\u304C\u51C4\u3044\u3088\u306A\u2026\u2026\n\u7B2C7\u5C64\u3068\u304B\u306B\u3057\u3068\u3051\u3070\u3088\u304B\u3063\u305F\u3001\u3082\u3046\u9045\u3044\u3051\u3069\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u305A\u306F\u30D0\u30F3\u30D1\u30A4\u30A2\u30AC\u30FC\u30EB\u3002\n\u80FD\u529B\u306F\u9AD8\u3044\u3093\u3060\u304C\u3001\u706B\u306B\u3082\u6C37\u306B\u3082\u5F31\u3044\u304B\u3089\u3001\n\u4E09\u9B54\u7A81\u304D\u3068\u304B\u3067\u30EF\u30F3\u30D1\u30F3\u304B\u3082\u306A\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B21\u306B\u30E9\u30DF\u30A2\u3002\u3053\u3053\u306B\u6765\u3066\u77F3\u5316\u653B\u6483\u304C\u5FA9\u6D3B\u3060\u3002\n\u6CB9\u65AD\u3057\u3066\u5BFE\u7B56\u5FD8\u308C\u3066\u305F\u3089\u53B3\u3057\u3044\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6700\u5F8C\u306B\u30DF\u30CE\u30BF\u30A6\u30ED\u30B9\u3002\u6012\u308A\u304B\u3089\u306E\u3076\u3093\u56DE\u3057\u306E\u5A01\u529B\u306F\n\u5B9F\u306B675\u3002\u9632\u5FA1\u3068\u304B\u3042\u308B\u3068\u306F\u3044\u3048\u3001HP500\u306F\u30AD\u30FC\u30D7\u3057\u305F\u3044\u306A\u3002"
