  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B63\u76F4\u554F\u984C\u306F15\u554F\u3057\u304B\u7528\u610F\u3057\u3066\u306A\u3044\u304B\u3089\u3001\n\u30B3\u30F3\u30C6\u30A3\u30CB\u30E5\u30FC\u3068\u304B\u3055\u308C\u308B\u3068\u3059\u3050\u306B\u91CD\u8907\u3060\u3089\u3051\u306B\u306A\u308B\u3093\u3060\u3088\u306A\u2026\u2026"
