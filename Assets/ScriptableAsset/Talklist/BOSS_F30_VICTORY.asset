  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u305F\u30AF\u30A4\u30BA\u30A4\u30D9\u30F3\u30C8\u306F\u767A\u751F\u3059\u308B\u304B\u3082\u3057\u308C\u306A\u3044\u304B\u3089\u3001\n\u3053\u308C\u304B\u3089\u3082\u79C1\u306E\u8A71\u306F\u3061\u3083\u3093\u3068\u805E\u3044\u3066\u304A\u3051\u3088\uFF1F"
