  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30A2\u30A4\u30C6\u30E0\u30B3\u30F3\u30D7\u52E2\u304B\u3089\u82E6\u60C5\u304C\u6765\u3066\u3044\u308B\u304C\u3001\n\u305D\u3082\u305D\u3082\u305D\u3093\u306A\u30D7\u30EC\u30A4\u30B9\u30BF\u30A4\u30EB\u3092\u524D\u63D0\u306B\n\u3053\u306E\u8A66\u7DF4\u306F\u4F5C\u3063\u3066\u306A\u3044\u304B\u3089\u306A\uFF01"
