  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u3053\u304B\u3089\u306F\u3053\u306E\u30A8\u30EA\u30A2\u306E\u5F37\u6575\u304C\u51FA\u308B\u305C\uFF01\n\u512A\u3057\u3044\u30D5\u30A7\u30B4\u30FC\u30EB\u3061\u3083\u3093\u304C\u89E3\u8AAC\u3057\u3066\u3084\u308D\u3046\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u305A\u306F\u898B\u7FD2\u3044\u30A6\u30A3\u30C3\u30C1\u3002\u898B\u7FD2\u3044\u3067\u546A\u6587\u306E\u8A60\u5531\u306F\u904B\u4EFB\u305B\u3002\n\u3053\u3063\u3061\u306E\u904B\u304C\u60AA\u3044\u3068\u5834\u9055\u3044\u306B\u5F37\u3044\u9B54\u6CD5\u3092\u653E\u3063\u3066\u304F\u308B\u304B\u3082\u306A\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B21\u306B\u7834\u58CA\u5149\u7DDA\u9283\u3002\u884C\u52D5\u30EB\u30FC\u30C1\u30F3\u306F\u5B8C\u5168\u306B\u56FA\u5B9A\u3060\u3002\n\u3060\u304B\u3089\u51B7\u9759\u306B\u5BFE\u51E6\u3059\u308C\u3070\u4F55\u3068\u304B\u306A\u308B\u3002\u5F31\u70B9\u3082\u3042\u308B\u3057\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6700\u5F8C\u306B1\u304B\u3089100\u30C0\u30E1\u30FC\u30B8\u304F\u3093\u3002\n\u9632\u5FA1\u306E\u30C0\u30E1\u30FC\u30B8\u8EFD\u6E1B\u306F\u53CD\u6620\u3055\u308C\u308B\u306B\u305B\u3088\u3001\n\u3053\u306E\u6BB5\u968E\u3067100\u3068\u304B\u9023\u767A\u3055\u308C\u305F\u3089\u56F0\u308B\u3088\u306A\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u5168\u6EC5\u3057\u3066\u3082\u6C17\u306B\u3059\u308B\u306A\u3001\u30AC\u30F3\u30AC\u30F3\u7A3C\u3044\u3067\n\u30B9\u30C6\u30FC\u30BF\u30B9\u3092\u4E0A\u3052\u3066\u30A2\u30A4\u30C6\u30E0\u96C6\u3081\u3066\u6311\u6226\u3060\uFF01"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
