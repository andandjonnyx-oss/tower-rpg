    text: "\u3053\u3053\u306E\u30EC\u30A2\u30E2\u30F3\u30B9\u30BF\u30FC\u306E\u884C\u52D5\u30D1\u30BF\u30FC\u30F3\u306F\n8\u5272\u3067HP=1\u30012\u5272\u3067\u30DD\u30A4\u30BA\u30F3\u3060\u3002"
