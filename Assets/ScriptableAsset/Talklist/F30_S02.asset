    text: "\u307E\u3041\u3001\u305D\u3082\u305D\u3082\u30EC\u30A2\u30E2\u30F3\u30B9\u30BF\u30FC\u3060\u3057\u3001\n\u906D\u9047\u3057\u306A\u3044\u3088\u3046\u306B\u304A\u7948\u308A\u306E\u304C\u73FE\u5B9F\u7684\u3060\u304C\u306A\u2026\u2026"
