  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B63\u76F44\u968E\u304B\u3089\u4E2D\u6575\u304C\u51FA\u3066\u6765\u3066\u3001\n6\u968E\u304B\u3089\u5F37\u6575\u304C\u51FA\u3066\u6765\u308B\u306E\u306F\n\u305B\u308F\u3057\u306A\u3055\u3059\u304E\u308B\u3088\u306A\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u305A\u306F\u30AF\u30B5\u30AC\u30E1\u3002\u30A4\u30E1\u30FC\u30B8\u901A\u308A\u3001\u7269\u7406\u306B\u5F37\u3044\u305C\u3002\n\u3068\u306F\u8A00\u3048\u30AF\u30EA\u30C6\u30A3\u30AB\u30EB\u3084\u9632\u5FA1\u8CAB\u901A\u3092\u6D3B\u7528\u3057\u3066\n\u7269\u7406\u578B\u3067\u62BC\u3057\u901A\u3059\u306E\u3082\u30A2\u30EA\u3060\u3088\u306A\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6B21\u306B\u30C8\u30EA\u30D7\u30EB\u30DE\u30FC\u30B8\u6539\u3002\n\u304A\u524D\u3082\u62FE\u3063\u305F\u304B\u3082\u3057\u308C\u306A\u3044\u9B54\u6CD5\u3001\n\u30C8\u30EA\u30D7\u30EB\u30DE\u30B8\u30C3\u30AF\u3092\u6483\u3063\u3066\u304F\u308B\u305E\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6700\u5F8C\u306B\u7D76\u5BFE100\u30C0\u30E1\u4E0E\u3048\u308B\u304F\u3093\u3002\n\u3053\u3053\u304B\u3089\u306F\u7D76\u5BFE\u306B\u6226\u95D8\u524D\u306BHP\u306F101\u4EE5\u4E0A\u306F\u78BA\u4FDD\u3057\u3068\u3051\u3088\u3002\n\u56DE\u907F\u3057\u306A\u3044\u9650\u308A\u7D76\u5BFE\u306B100\u30C0\u30E1\u30FC\u30B8\u3060\u304B\u3089\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
