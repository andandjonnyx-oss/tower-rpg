  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "STR50\u6BCE\u306B\u3001\u6301\u3061\u7269\u306E\u4E0A\u9650\u304C1\u5897\u3048\u308B\u3088\u3046\u306B\u3057\u3066\u308B\u305C\u3002\n\u6700\u592730\u500B\u307E\u3067\u3060\u3002\u307E\u3041STR500\u306B\u3059\u308B\u307E\u3067\u3084\u308A\u8FBC\u3080\u30D7\u30EC\u30A4\u30E4\u30FC\u306F\u3001\n\u65E9\u3005\u3044\u306A\u3044\u3068\u601D\u3046\u304C\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u30B9\u30C6\u30FC\u30BF\u30B9\u30EA\u30BB\u30C3\u30C8\u3068\u304B\u3059\u308B\u6642\u306F\u3001\u30A2\u30A4\u30C6\u30E0\u304C21\u500B\u8D8A\u3057\u3066\u305F\u3089\n\u8B66\u544A\u5165\u3063\u3066\u51FA\u6765\u306A\u3044\u3088\u3046\u306B\u3057\u3066\u308B\u304B\u3089\u306A\u3002\n\u3061\u3083\u3093\u3068\u6574\u7406\u3057\u3066\u304B\u3089\u30EA\u30BB\u30C3\u30C8\u3059\u308B\u3093\u3060\u305E\u3002"
