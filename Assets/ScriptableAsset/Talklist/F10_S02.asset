  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u3041\u307E\u3041\u5F37\u3044\u3051\u3069\u3001\n\u5012\u3059\u3068\u78BA\u5B9F\u306B\u30B9\u30C6\u30FC\u30BF\u30B9\u30A2\u30C3\u30D7\u30A2\u30A4\u30C6\u30E0\u3092\u843D\u3068\u3059\u305E\uFF01"
