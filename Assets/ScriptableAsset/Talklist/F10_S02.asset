    text: "10\u968E\u306B\u306F\u3044\u308F\u3086\u308B\u30EC\u30A2\u30E2\u30F3\u30B9\u30BF\u30FC\u304C\u3044\u308B\u305E\uFF01\n\u51FA\u73FE\u7387\u3082\u4ED6\u306E\u30E2\u30F3\u30B9\u30BF\u30FC\u3088\u308A\u4F4E\u3081\u3060\uFF01"
