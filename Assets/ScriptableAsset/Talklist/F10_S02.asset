  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u3041\u77E5\u3063\u3066\u306E\u901A\u308A\u5F8C\u308D\u306B\u306F\u623B\u308C\u306A\u3044\u3057\u3001\n10\u968E\u307E\u3067\u6765\u3066\u7A3C\u3050\u306E\u306F\u975E\u52B9\u7387\u3060\u308D\uFF1F\n\u5012\u305B\u305F\u3089\u30E9\u30C3\u30AD\u30FC\u3001\u7A0B\u5EA6\u306B\u601D\u3063\u3066\u304A\u3053\u3046\u306A\uFF1F"
