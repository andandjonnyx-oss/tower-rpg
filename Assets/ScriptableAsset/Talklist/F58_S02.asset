  zukanTitle: "\u305D\u3093\u306A\u306B\u9AD8\u304F\u306A\u3044\u5854"
  floor: 58
  step: 2
  backgroundImage: {fileID: -5642793763813460095, guid: d227693ff385d6b42b19c6ffd3512034, type: 3}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u5185\u90E8\u3092\u9B54\u6CD5\u306E\u529B\u3067\u3044\u3058\u3063\u3066\u308B\u304B\u3089\u3001\n\u5916\u304B\u3089\u306E\u5927\u304D\u3055\u3068\u304B\u3069\u3046\u3067\u3082\u3044\u3044\u3093\u3060\u3051\u3069\u3001\n\u3053\u306E\u5854\u306F1\u968E\u3042\u305F\u308A5m\u3067\u3001500m\u304F\u3089\u3044\u306E\u9AD8\u3055\u3060\u305C\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u6EC5\u8336\u82E6\u8336\u9AD8\u3044\u3060\u308D\u3046\uFF1F\n\u304A\u524D\u3060\u3063\u3066\u3001\u3053\u306E\u5854\u306E\u3067\u304B\u3055\u306B\u8208\u5473\u3092\u6301\u3063\u3066\n\u3053\u306E\u8857\u306B\u3084\u3063\u3066\u6765\u305F\u3093\u3060\u308D\u3046\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u2026\u2026\u3068\u601D\u3063\u305F\u3093\u3060\u3051\u3069\u3001\u3053\u306E\u524D\u9060\u898B\u306E\u9B54\u6CD5\u3067\n\u30B8\u30D1\u30F3\u30B0\u3092\u89B3\u5149\u3057\u3066\u305F\u3089\u3001\u666E\u901A\u306B\u3053\u3053\u3088\u308A\u3067\u304B\u3044\u5854\u304C\u3042\u3063\u305F\u3002\n\u6570\u767E\u5E74\u306E\u9593\u306B\u4EBA\u9593\u306E\u6587\u5316\u306F\u968F\u5206\u9032\u3093\u3060\u3093\u3060\u306A\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
  rewardItem: {fileID: 0}
