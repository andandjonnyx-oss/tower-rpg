  backgroundImage: {fileID: 0}
  lines:
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3082\u3050\u3082\u3050\u2026\u2026\u3093\u3001\u304A\u524D\u3082\u6B32\u3057\u3044\u306E\u304B\uFF1F\n\u3057\u3087\u3046\u304C\u306A\u3044\u306A\u3001\u7279\u5225\u306B\u30C6\u30A3\u30E9\u30DF\u30B9\u306E\u3092\u5F8C\u3067\u3084\u308B\u3088\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u305D\u308C\u3088\u308A\u4F55\u306A\u3093\u3060\u3053\u308C\u306F\u2026\u2026\uFF1F\n\u30C0\u30F3\u30B8\u30E7\u30F3\u306E\u4E2D\u306B\u3082\u3084\u305F\u3089\u843D\u3061\u3066\u308B\u3093\u3060\u304C\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u304A\u3044\u304A\u3044\u300118\u30A2\u30A4\u30B9\u3092\u77E5\u3089\u306A\u3044\u3067\u65C5\u4EBA\u540D\u4E57\u3063\u3066\u308B\u306E\u304B\u3088\u3002\n\u3053\u308C\u306F\u6771\u306B\u3042\u308B\u30B8\u30D1\u30F3\u30B0\u3063\u3066\u56FD\u3067\u4F5C\u3089\u308C\u3066\u3044\u308B\u6C37\u3067\u51FA\u6765\u305F\u304A\u83D3\u5B50\u306A\u3093\u3060\u3002\n\u884C\u3063\u305F\u3053\u3068\u7121\u3044\u306E\u304B\uFF1F"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: You
    text: "\u805E\u3044\u305F\u3053\u3068\u306F\u3042\u308B\u304C\u3001\u304B\u306A\u308A\u9060\u3044\u304B\u3089\u306A\u3002\n\u307E\u3060\u884C\u3063\u305F\u3053\u3068\u306F\u7121\u3044\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u307E\u3041\u79C1\u3082\u884C\u3063\u305F\u3053\u3068\u306F\u7121\u3044\u3093\u3060\u3051\u3069\u306A\u3002\n\u79C1\u306F\u5854\u306E\u5B88\u8B77\u8005\u3060\u304B\u3089\u3001\u30A2\u30A4\u30C6\u30E0\u540C\u69D8\u306B\u753A\u306E\u5916\u306B\u306F\u51FA\u308C\u306A\u3044\u3093\u3060\u3002\n\u3060\u3051\u3069\u9060\u898B\u306E\u9B54\u6CD5\u304C\u4F7F\u3048\u308B\u304B\u3089\u3001\u305D\u308C\u3067\u8272\u3093\u306A\u4E16\u754C\u3092\u898B\u3066\u308B\u306E\u3055\u3002"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3053\u306E\u30A2\u30A4\u30B9\u3082\u3001\u898B\u3066\u30A4\u30E1\u30FC\u30B8\u3057\u3066\u4F5C\u3063\u305F\u3060\u3051\u3067\u3001\n\u5B9F\u7269\u306F\u98DF\u3079\u305F\u4E8B\u304C\u7121\u3044\u3093\u3060\u3088\u306A\u3041\u3002\n\u672C\u7269\u306F\u3082\u3063\u3068\u7F8E\u5473\u3057\u3044\u306E\u304B\u306A\u3041\u2026\u2026"
    portrait: {fileID: -9110550355602550490, guid: 1c9a759beefc7a545b788047293b1cf3, type: 3}
    backgroundOverride: {fileID: 0}
  conditions: []
  rewardItem: {fileID: 11400000, guid: a9a049a4187c3594a803b70cfef9fb42, type: 2}
