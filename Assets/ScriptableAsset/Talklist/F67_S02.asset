    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u304A\u524D\u304C\u3053\u306E\u5854\u306B\u6765\u3066\u304B\u3089\u65E9\u2026\u2026\n\u3069\u308C\u304F\u3089\u3044\u7D4C\u3063\u3066\u308B\u3093\u3060\u308D\u3046\u306A\uFF1F\n\u6642\u9593\u306E\u611F\u899A\u304C\u308F\u304B\u3093\u306D\u30FC\u3084\u3002"
