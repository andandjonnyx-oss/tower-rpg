    backgroundOverride: {fileID: 0}
  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "\u3068\u306B\u304B\u304F\u3001\u3053\u3093\u306A\u4E2D\u9014\u534A\u7AEF\u306A\u3068\u3053\u308D\u3067\u8F9E\u3081\u306A\u3044\u3067\u304F\u308C\u3088\uFF1F\n\u30A8\u30F3\u30C7\u30A3\u30F3\u30B0\u307E\u3067\u7A81\u3063\u8D70\u308D\u3046\u305C\uFF01"
