  - speaker: "\u30D5\u30A7\u30B4\u30FC\u30EB"
    text: "100\u968E\u306E\u3046\u306166\u968E\u3092\u30AF\u30EA\u30A2\u2026\u2026\n\u3082\u3046\u6B8B\u308A3\u5206\u306E1\u304B\u3041\u2026\u2026\n\u3053\u3053\u307E\u3067\u3042\u3063\u3068\u8A00\u3046\u9593\u3060\u3063\u305F\u306A\u2026\u2026"
